{
	"$schema": "https://emdashcms.com/seed.schema.json",
	"version": "1",
	"meta": {
		"name": "Ambitions AI",
		"description": "Learning Centre — expert guides, strategies and insights for service businesses",
		"author": "Ambitions AI"
	},

	"settings": {
		"title": "Ambitions AI",
		"tagline": "AI Marketing for Service Businesses"
	},

	"collections": [
		{
			"slug": "posts",
			"label": "Posts",
			"labelSingular": "Post",
			"supports": ["drafts", "revisions", "search", "seo"],
			"commentsEnabled": false,
			"fields": [
				{
					"slug": "title",
					"label": "Title",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "meta_description",
					"label": "Meta Description",
					"type": "text",
					"required": false,
					"searchable": false
				},
				{
					"slug": "excerpt",
					"label": "Excerpt",
					"type": "text",
					"required": false
				},
				{
					"slug": "featured_image",
					"label": "Featured Image",
					"type": "image"
				},
				{
					"slug": "content",
					"label": "Content",
					"type": "portableText",
					"searchable": true
				}
			]
		}
	],

	"taxonomies": [
		{
			"name": "category",
			"label": "Categories",
			"labelSingular": "Category",
			"hierarchical": false,
			"collections": ["posts"],
			"terms": [
				{ "slug": "aeo-seo", "label": "AEO & SEO" },
				{ "slug": "content-marketing", "label": "Content Marketing" },
				{ "slug": "ai-marketing", "label": "AI & Marketing" },
				{ "slug": "reviews-reputation", "label": "Reviews & Reputation" },
				{ "slug": "business-growth", "label": "Business Growth" },
				{ "slug": "website-design", "label": "Website & Design" },
				{ "slug": "endless-customers", "label": "Endless Customers™" }
			]
		},
		{
			"name": "tag",
			"label": "Tags",
			"labelSingular": "Tag",
			"hierarchical": false,
			"collections": ["posts"],
			"terms": [
				{ "slug": "how-to", "label": "How To" },
				{ "slug": "strategy", "label": "Strategy" },
				{ "slug": "ai", "label": "Artificial Intelligence" },
				{ "slug": "local-business", "label": "Local Business" },
				{ "slug": "content", "label": "Content" },
				{ "slug": "reviews", "label": "Reviews" },
				{ "slug": "sales", "label": "Sales" },
				{ "slug": "tools", "label": "Tools & Tech" },
				{ "slug": "case-study", "label": "Case Study" }
			]
		}
	],

	"bylines": [
		{
			"id": "byline-nick",
			"slug": "nick-burrage",
			"displayName": "Nick Burrage"
		},
		{
			"id": "byline-editorial",
			"slug": "ambitions-ai-editorial",
			"displayName": "Ambitions AI Editorial"
		}
	],

	"menus": [
		{
			"name": "primary",
			"label": "Primary Navigation",
			"items": [
				{ "type": "custom", "label": "Home", "url": "/" },
				{ "type": "custom", "label": "Learning Centre", "url": "/learning-centre/" },
				{ "type": "custom", "label": "Pricing", "url": "/pricing/" },
				{ "type": "custom", "label": "Contact", "url": "/contact/" }
			]
		}
	],

	"content": {
		"posts": []
	}
}
