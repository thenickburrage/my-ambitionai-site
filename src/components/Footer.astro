---
import { site, nav, socialLinks, services } from '@/data/site';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-200 bg-gray-50 dark:border-gray-800 dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-4 py-16 lg:px-8 lg:py-20">
    <div class="grid gap-12 lg:grid-cols-4">
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block">
          <img
            src={site.logo.src}
            alt={site.logo.alt}
            class="h-8 w-auto dark:hidden"
          />
          <img
            src={site.logo.srcLight}
            alt={site.logo.alt}
            class="hidden h-8 w-auto dark:block"
          />
        </a>
        <p class="mt-4 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
          {site.description}
        </p>
        <!-- Social Links -->
        <div class="mt-6 flex gap-4">
          {socialLinks.map((social) => (
            <a
              href={social.url}
              class="rounded-lg bg-gray-200 p-2.5 text-gray-600 transition-colors hover:bg-primary-500 hover:text-white dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-primary-500 dark:hover:text-white"
              aria-label={social.name}
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation Links -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-900 dark:text-white">
          Navigation
        </h4>
        <ul class="mt-4 space-y-3">
          {nav.map((item) => (
            <li>
              <a
                href={item.url}
                class="text-sm text-gray-600 transition-colors hover:text-primary-500 dark:text-gray-400 dark:hover:text-primary-400"
              >
                {item.text}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services Links -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-900 dark:text-white">
          Services
        </h4>
        <ul class="mt-4 space-y-3">
          {services.map((service) => (
            <li>
              <a
                href="/services"
                class="text-sm text-gray-600 transition-colors hover:text-primary-500 dark:text-gray-400 dark:hover:text-primary-400"
              >
                {service.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-900 dark:text-white">
          Contact
        </h4>
        <ul class="mt-4 space-y-3 text-sm text-gray-600 dark:text-gray-400">
          <li>
            <a
              href={`mailto:${site.email}`}
              class="transition-colors hover:text-primary-500 dark:hover:text-primary-400"
            >
              {site.email}
            </a>
          </li>
          <li>
            <a
              href={`tel:${site.phone.replace(/[^+\d]/g, '')}`}
              class="transition-colors hover:text-primary-500 dark:hover:text-primary-400"
            >
              {site.phone}
            </a>
          </li>
          <li class="pt-2">
            <address class="not-italic leading-relaxed">
              {site.address.street}<br />
              {site.address.city}, {site.address.state} {site.address.zip}
            </address>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-gray-200 pt-8 dark:border-gray-800 sm:flex-row">
      <p class="text-sm text-gray-600 dark:text-gray-400">
        &copy; {currentYear} {site.name}. All rights reserved.
      </p>
      <div class="flex gap-6 text-sm">
        <a
          href="/privacy"
          class="text-gray-600 transition-colors hover:text-primary-500 dark:text-gray-400 dark:hover:text-primary-400"
        >
          Privacy Policy
        </a>
        <a
          href="/terms"
          class="text-gray-600 transition-colors hover:text-primary-500 dark:text-gray-400 dark:hover:text-primary-400"
        >
          Terms of Service
        </a>
      </div>
    </div>
  </div>
</footer>
