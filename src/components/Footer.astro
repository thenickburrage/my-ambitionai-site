---
import { site, nav, socialLinks, footerServices, trustLinks, footerAuthors } from '@/data/site';
---

<footer class="border-t border-gray-200 bg-gray-50 dark:border-gray-800 dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-4 py-16 lg:px-8 lg:py-20">
    <div class="grid gap-12 lg:grid-cols-6">
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block">
          <img
            src={site.logo.src}
            alt={site.logo.alt}
            class="h-10 w-auto"
          />
        </a>
        <p class="mt-4 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
          {site.description}
        </p>
        <!-- Contact -->
        <div class="mt-4 space-y-1 text-sm text-gray-600 dark:text-gray-400">
          <p>
            <a
              href={`tel:${site.phone.replace(/[^+\d]/g, '')}`}
              class="transition-colors hover:text-primary-500 dark:hover:text-primary-400"
            >
              {site.phone}
            </a>
          </p>
          <p>{site.address.city}, {site.address.zip}</p>
        </div>
        <!-- Social Links -->
        <div class="mt-6 flex gap-4">
          {socialLinks.map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg bg-gray-200 p-2.5 text-gray-600 transition-colors hover:bg-primary-500 hover:text-white dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-primary-500 dark:hover:text-white"
              aria-label={social.name}
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation Links -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-900 dark:text-white">
          Navigation
        </h4>
        <ul class="mt-4 space-y-3">
          {nav.map((item) => (
            <li>
              <a
                href={item.url}
                class="text-sm text-gray-600 transition-colors hover:text-primary-500 dark:text-gray-400 dark:hover:text-primary-400"
              >
                {item.text}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services / Legacy Links -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-900 dark:text-white">
          Services
        </h4>
        <ul class="mt-4 space-y-3">
          {footerServices.map((item) => (
            <li>
              <a
                href={item.url}
                class="text-sm text-gray-600 transition-colors hover:text-primary-500 dark:text-gray-400 dark:hover:text-primary-400"
              >
                {item.text}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Authors -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-900 dark:text-white">
          Our Authors
        </h4>
        <ul class="mt-4 space-y-3">
          {footerAuthors.map((item) => (
            <li>
              <a
                href={item.url}
                class="text-sm text-gray-600 transition-colors hover:text-primary-500 dark:text-gray-400 dark:hover:text-primary-400"
              >
                {item.text}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Trust and Transparency -->
      <div class="lg:col-span-2">
        <h4 class="text-sm font-semibold uppercase tracking-wider text-gray-900 dark:text-white">
          Trust and Transparency
        </h4>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
          {trustLinks.map((item) => (
            <li>
              <a
                href={item.url}
                class="text-sm text-gray-600 transition-colors hover:text-primary-500 dark:text-gray-400 dark:hover:text-primary-400"
              >
                {item.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 flex flex-col items-center justify-between gap-2 border-t border-gray-200 pt-8 dark:border-gray-800 sm:flex-row">
      <p class="text-sm text-gray-600 dark:text-gray-400">
        &copy; 2026 Ambitions AI. All rights reserved.
      </p>
      <p class="text-xs text-gray-500 dark:text-gray-500">
        Ambitions AI is a trading name of Ambitions Web Limited. UK Reg No. 153 87 454
      </p>
    </div>
  </div>
</footer>
