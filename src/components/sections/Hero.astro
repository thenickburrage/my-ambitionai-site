---
import { site, stats } from '@/data/site';

interface Props {
  title?: string;
  subtitle?: string;
  showStats?: boolean;
}

const {
  title = 'We Create <span class="text-gradient">Bold Digital</span> Experiences',
  subtitle = site.description,
  showStats = true,
} = Astro.props;
---

<section class="relative overflow-hidden hero-gradient">
  <!-- Radial glow overlays -->
  <div class="absolute inset-0 opacity-40">
    <div class="absolute -left-20 top-0 h-96 w-96 rounded-full bg-primary-300 blur-[120px]"></div>
    <div class="absolute -right-20 bottom-0 h-96 w-96 rounded-full bg-accent-200 blur-[120px]"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 py-28 lg:px-8 lg:py-40">
    <div class="mx-auto max-w-4xl text-center">
      <!-- Badge -->
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary-300 bg-white/70 px-4 py-1.5 text-sm font-medium text-primary-600 backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-primary-500"></span>
        </span>
        Award-Winning Creative Agency
      </div>

      <!-- Title -->
      <h1
        class="text-5xl font-bold leading-tight tracking-tight text-gray-900 sm:text-6xl lg:text-7xl"
        set:html={title}
      />

      <!-- Subtitle -->
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 lg:text-xl">
        {subtitle}
      </p>

      <!-- CTA Buttons -->
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/work"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-primary-500 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-500/25 transition-all hover:bg-primary-600 hover:shadow-xl hover:shadow-primary-500/30"
        >
          View Our Work
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-gray-300 bg-white/80 px-8 py-4 text-base font-semibold text-gray-700 backdrop-blur-sm transition-all hover:border-gray-400 hover:bg-white"
        >
          Start a Project
        </a>
      </div>
    </div>

    <!-- Stats -->
    {showStats && (
      <div class="mt-20 grid grid-cols-2 gap-8 border-t border-gray-200/60 pt-12 sm:grid-cols-4">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl font-bold text-gray-900 lg:text-4xl">
              {stat.value}
            </div>
            <div class="mt-1 text-sm text-gray-600">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2">
    <a href="#services" class="flex flex-col items-center gap-3 text-gray-400 transition-colors hover:text-primary-500">
      <span class="text-xs font-medium uppercase tracking-widest">Scroll</span>
      <div class="relative flex h-10 w-6 items-start justify-center rounded-full border-2 border-current pt-2">
        <div class="h-2 w-1 animate-scroll-indicator rounded-full bg-current"></div>
      </div>
    </a>
  </div>
</section>
