---
import { projects } from '@/data/site';

interface Props {
  title?: string;
  subtitle?: string;
  featured?: boolean;
  limit?: number;
  showFilters?: boolean;
}

const {
  title = 'Selected Work',
  subtitle = 'A showcase of our best projects across branding, web design, and digital experiences.',
  featured = true,
  limit = 6,
  showFilters = false,
} = Astro.props;

const displayProjects = featured
  ? projects.filter((p) => p.featured).slice(0, limit)
  : projects.slice(0, limit);

const categories = [...new Set(projects.map((p) => p.category))];
---

<section class="bg-gray-50 py-20 dark:bg-gray-900 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <!-- Section Header -->
    <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
      <div>
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl lg:text-5xl">
          {title}
        </h2>
        <p class="mt-4 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
          {subtitle}
        </p>
      </div>
      <a
        href="/work"
        class="inline-flex items-center gap-2 text-sm font-semibold text-primary-500 transition-colors hover:text-primary-600"
      >
        View All Projects
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <!-- Filters (optional) -->
    {showFilters && (
      <div class="mt-10 flex flex-wrap gap-3">
        <button
          class="rounded-full bg-primary-500 px-5 py-2 text-sm font-medium text-white"
          data-filter="all"
        >
          All
        </button>
        {categories.map((category) => (
          <button
            class="rounded-full border border-gray-300 px-5 py-2 text-sm font-medium text-gray-700 transition-colors hover:border-primary-500 hover:text-primary-500 dark:border-gray-700 dark:text-gray-300 dark:hover:border-primary-500 dark:hover:text-primary-400"
            data-filter={category}
          >
            {category}
          </button>
        ))}
      </div>
    )}

    <!-- Projects Grid -->
    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {displayProjects.map((project, index) => (
        <a
          href={`/work/${project.slug}`}
          class="group relative overflow-hidden rounded-2xl bg-gray-900"
          data-animate
          style={`animation-delay: ${index * 100}ms`}
        >
          <!-- Image -->
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={project.thumbnail}
              alt={project.title}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
          </div>

          <!-- Overlay -->
          <div class="absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-gray-900 via-gray-900/60 to-transparent p-6 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
            <span class="text-xs font-medium uppercase tracking-wider text-primary-400">
              {project.category}
            </span>
            <h3 class="mt-2 text-xl font-bold text-white">
              {project.title}
            </h3>
            <p class="mt-2 line-clamp-2 text-sm text-gray-300">
              {project.description}
            </p>
          </div>

          <!-- Always visible label -->
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-gray-900/90 to-transparent p-6 transition-opacity duration-300 group-hover:opacity-0">
            <span class="text-xs font-medium uppercase tracking-wider text-primary-400">
              {project.category}
            </span>
            <h3 class="mt-1 text-lg font-bold text-white">
              {project.title}
            </h3>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
