---
import { services } from '@/data/site';

interface Props {
  title?: string;
  subtitle?: string;
  showFeatures?: boolean;
}

const {
  title = 'What We Do',
  subtitle = 'We offer a full range of creative services to help your business stand out and succeed in the digital world.',
  showFeatures = true,
} = Astro.props;
---

<section class="bg-white py-20 dark:bg-gray-950 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <!-- Section Header -->
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl lg:text-5xl">
        {title}
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
        {subtitle}
      </p>
    </div>

    <!-- Services Grid -->
    <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {services.map((service, index) => (
        <div
          class="group relative rounded-2xl border border-gray-200 bg-white p-8 transition-all hover:border-primary-300 hover:shadow-xl hover:shadow-primary-500/10 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-primary-700"
          data-animate
          style={`animation-delay: ${index * 100}ms`}
        >
          <!-- Icon -->
          <div class="mb-6 inline-flex rounded-xl bg-gradient-to-br from-primary-500 to-accent-500 p-3 text-white shadow-lg shadow-primary-500/25">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <Fragment set:html={service.icon} />
            </svg>
          </div>

          <!-- Title -->
          <h3 class="text-xl font-bold text-gray-900 dark:text-white">
            {service.title}
          </h3>

          <!-- Description -->
          <p class="mt-3 text-gray-600 dark:text-gray-400">
            {service.description}
          </p>

          <!-- Features List -->
          {showFeatures && service.features && (
            <ul class="mt-6 space-y-2">
              {service.features.map((feature) => (
                <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                  <svg class="h-4 w-4 flex-shrink-0 text-primary-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
          )}

          <!-- Arrow Link -->
          <div class="mt-6">
            <a
              href="/services"
              class="inline-flex items-center gap-2 text-sm font-semibold text-primary-500 transition-colors hover:text-primary-600"
            >
              Learn More
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
