---
import { testimonials } from '@/data/site';

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'What Clients Say',
  subtitle = "Don't just take our word for it. Here's what our clients have to say about working with us.",
} = Astro.props;
---

<section class="bg-gray-50 py-20 dark:bg-gray-900 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <!-- Section Header -->
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl lg:text-5xl">
        {title}
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
        {subtitle}
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="mt-16 grid gap-8 lg:grid-cols-3">
      {testimonials.map((testimonial, index) => (
        <div
          class="relative rounded-2xl bg-white p-8 shadow-sm dark:bg-gray-800"
          data-animate
          style={`animation-delay: ${index * 100}ms`}
        >
          <!-- Quote Icon -->
          <svg
            class="absolute right-8 top-8 h-12 w-12 text-gray-100 dark:text-gray-700"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>

          <!-- Content -->
          <div class="relative">
            <!-- Stars -->
            <div class="flex gap-1 text-yellow-400">
              {[...Array(5)].map(() => (
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Quote -->
            <blockquote class="mt-6 text-gray-700 dark:text-gray-300">
              "{testimonial.text}"
            </blockquote>

            <!-- Author -->
            <div class="mt-8 flex items-center gap-4">
              {testimonial.image && (
                <img
                  src={testimonial.image}
                  alt={testimonial.name}
                  class="h-12 w-12 rounded-full object-cover"
                  loading="lazy"
                />
              )}
              <div>
                <div class="font-semibold text-gray-900 dark:text-white">
                  {testimonial.name}
                </div>
                <div class="text-sm text-gray-600 dark:text-gray-400">
                  {testimonial.role}, {testimonial.company}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
