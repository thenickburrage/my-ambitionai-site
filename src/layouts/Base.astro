---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { site } from '@/data/site';
import '@/css/input.css';

interface Props {
  title: string;
  description?: string;
  metaTitle?: string;
  canonicalPath?: string;
}

const { title, description = site.description, metaTitle, canonicalPath } = Astro.props;
const pageTitle = metaTitle ?? (title === 'Home' ? `${site.name} | ${site.tagline}` : `${title} | ${site.name}`);

// Canonicals always point to the production domain so search engines and
// AI engines can reconcile the staging and production URLs correctly at
// DNS cutover. If a page needs a custom canonical (e.g. an alternate
// representation), it can pass `canonicalPath` explicitly.
const PROD_ORIGIN = 'https://theambitionsagency.com';
const pathForCanonical = (canonicalPath ?? Astro.url.pathname) || '/';
// Normalise to a trailing slash for every path except the root.
const normalisedPath = pathForCanonical === '/'
  ? '/'
  : (pathForCanonical.endsWith('/') ? pathForCanonical : pathForCanonical + '/');
const canonicalUrl = `${PROD_ORIGIN}${normalisedPath}`;

const schemaMarkup = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': 'https://theambitionsagency.com/#organization',
  name: 'Ambitions AI',
  legalName: 'Ambitions Web Limited',
  url: 'https://theambitionsagency.com',
  logo: 'https://theambitionsagency.com/images/AAI_HEADERLOGO.webp',
  image: 'https://theambitionsagency.com/images/NICK_B.png',
  telephone: '+441752830000',
  priceRange: 'From £1,500/month',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '80 Magdalen Road',
    addressLocality: 'Exeter',
    postalCode: 'EX2 4TT',
    addressCountry: 'GB',
  },
  areaServed: ['GB', 'US'],
  sameAs: [
    'https://www.facebook.com/theambitionsagency',
    'https://www.linkedin.com/company/theambitionsagency/',
    'https://www.youtube.com/channel/UC2qcsJG2TXOuzJpGOImmVnw',
    'https://www.instagram.com/theambitionsagency',
  ],
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />


    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} />

    <!-- Google Analytics (GA4) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-FMVBRZX3G4"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-FMVBRZX3G4');
    </script>

    <!-- Per-page additional head content (schema, etc.) -->
    <slot name="head" />

    <!-- Dark mode flash prevention -->
    <script is:inline>
      if (localStorage.getItem('theme') === 'dark' ||
          (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="min-h-screen bg-white antialiased dark:bg-gray-950 dark:text-gray-100" style="color: #1a1a1a">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline>
      // Dark mode toggle
      (function () {
        var btn = document.getElementById('theme-toggle');
        if (btn) {
          btn.addEventListener('click', function () {
            var dark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('theme', dark ? 'dark' : 'light');
          });
        }

        // Mobile menu toggle
        var menuBtn = document.getElementById('mobile-menu-toggle');
        var menu = document.getElementById('mobile-menu');
        if (menuBtn && menu) {
          menuBtn.addEventListener('click', function () {
            var hidden = menu.classList.toggle('hidden');
            menuBtn.setAttribute('aria-expanded', hidden ? 'false' : 'true');
          });
        }

        // Header scroll state
        var hdr = document.querySelector('[data-header]');
        if (hdr) {
          var onScroll = function () { hdr.classList.toggle('scrolled', window.scrollY > 10); };
          window.addEventListener('scroll', onScroll, { passive: true });
          onScroll();
        }
      })();
    </script>
  </body>
</html>
