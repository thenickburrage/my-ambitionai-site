---
import { env } from 'cloudflare:workers';
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "@/layouts/Base.astro";

const { slug } = Astro.params;

// Try posts first, then pages
const { entry: post } = await getEmDashEntry("posts", slug!);
const { entry: page } = !post ? await getEmDashEntry("pages", slug!) : { entry: null };

if (!post && !page) {
  return Astro.redirect("/404");
}

const isPost = !!post;
const data = (post ?? page)!.data;

// Extract a plain-text excerpt from the first Portable Text block
function getExcerpt(content: unknown): string {
  if (!Array.isArray(content)) return "";
  const firstBlock = content.find(
    (b: { _type?: string; children?: unknown[] }) =>
      b._type === "block" && Array.isArray(b.children)
  );
  if (!firstBlock) return "";
  return (firstBlock.children as { text?: string }[])
    .map((span) => span.text ?? "")
    .join("")
    .trim()
    .slice(0, 160);
}

// SEO description: prefer explicit meta_description, then excerpt field, then derived
const description =
  (data.meta_description as string | undefined) ||
  (data.excerpt as string | undefined) ||
  getExcerpt(data.content) ||
  String(data.title);

const publishedISO = (data.post_date ?? data.publishedAt ?? data.createdAt)
  ? new Date((data.post_date ?? data.publishedAt ?? data.createdAt) as string).toISOString().split("T")[0]
  : null;

const publishedDate = publishedISO
  ? new Date(publishedISO).toLocaleDateString("en-GB", {
      day: "numeric",
      month: "long",
      year: "numeric",
    })
  : null;

const updatedISO = data.updated_date
  ? new Date(data.updated_date as string).toISOString().split("T")[0]
  : null;

const updatedDate = updatedISO
  ? new Date(updatedISO).toLocaleDateString("en-GB", {
      day: "numeric",
      month: "long",
      year: "numeric",
    })
  : null;

const authorName =
  (data.bylines as { byline?: { displayName?: string } }[] | undefined)?.[0]
    ?.byline?.displayName ?? "Ambitions AI";

const authorPageMap: Record<string, string> = {
  "Nick Burrage": "/authors/nick-burrage/",
  "Liyana van Wyk": "/authors/liyana-van-wyk/",
  "Liyana V.": "/authors/liyana-van-wyk/",
};
const authorUrl = authorPageMap[authorName] ?? null;

// R2-hosted author photos (400×400 source, displayed at 200×200)
// Add entries here as photos are uploaded to R2
const authorPhotoMap: Record<string, string> = {
  // "Nick Burrage": "https://media.theambitionsagency.com/authors/nick-burrage-400x400.jpg",
  "Liyana van Wyk": "https://media.theambitionsagency.com/authors/liyana-van-wyck.webp",
};
const authorPhoto = authorPhotoMap[authorName] ?? null;

// Author bio paragraphs (rendered in the byline card)
const authorBioMap: Record<string, Array<{ text: string; link?: { href: string; text: string } }>> = {
  "Liyana van Wyk": [
    { text: "If this article made your head spin a little, good. That means you are paying attention. Search has genuinely changed and there is a lot to get across. What I love about this work is breaking it down for businesses who are brilliant at what they do but have not got time to become SEO nerds. That is my job. You just focus on what you are good at and let me handle the rest." },
    { text: "More articles on my page, plus an easy way to get in touch. Come and find me. ", link: { href: "/authors/liyana-van-wyk/", text: "Find me here →" } },
  ],
  "Nick Burrage": [
    { text: "I will be honest with you: I have not yet found a paid AI visibility tool that I feel confident recommending to our clients as a must-have. That might change, and when it does I will update this article and tell you why. What I do know is that the clients getting the best AI visibility results right now are not the ones with the fanciest dashboards — they are the ones with the clearest, most useful content on the web. That is what we help you build." },
    { text: "More on my page, including how to work with me if you are serious about growth. ", link: { href: "/authors/nick-burrage/", text: "Find me here →" } },
  ],
};
const authorBio = authorBioMap[authorName] ?? null;
const authorFirstName = authorName.split(" ")[0];

const featuredImage = data.featured_image as
  | { src?: string; alt?: string }
  | undefined;

const pageUrl = `https://theambitionsagency.com/${slug}/`;

// Article schema (blog posts only)
const articleSchema = isPost ? {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      "@id": `${pageUrl}#article`,
      "headline": data.title,
      "description": description,
      "url": pageUrl,
      ...(publishedISO ? { "datePublished": publishedISO, "dateModified": updatedISO ?? publishedISO } : {}),
      ...(featuredImage?.src ? { "image": featuredImage.src } : {}),
      "author": {
        "@type": "Person",
        "@id": "https://theambitionsagency.com/#nick-burrage",
        "name": authorName
      },
      "publisher": {
        "@id": "https://theambitionsagency.com/#organization"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": pageUrl
      },
      "isPartOf": {
        "@type": "WebSite",
        "url": "https://theambitionsagency.com",
        "name": "Ambitions AI"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://theambitionsagency.com/" },
        { "@type": "ListItem", "position": 2, "name": "Learning Centre", "item": "https://theambitionsagency.com/learning-centre/" },
        { "@type": "ListItem", "position": 3, "name": String(data.title), "item": pageUrl }
      ]
    }
  ]
} : null;

// ── Related posts (blog posts only) ──
type RelatedRow = {
  slug: string;
  title: string;
  excerpt: string | null;
  featured_image: string | null;
  post_date: string | null;
  published_at: string | null;
  created_at: string;
};

let relatedPosts: RelatedRow[] = [];

if (isPost) {
  const db = env.DB as D1Database;
  const postId = post!.data.id as string;

  // 1. Get this post's category IDs
  const { results: cats } = await db
    .prepare(
      `SELECT taxonomy_id FROM content_taxonomies WHERE entry_id = ? AND collection = 'posts'`
    )
    .bind(postId)
    .all<{ taxonomy_id: string }>();

  const catIds = cats.map((c) => c.taxonomy_id);

  if (catIds.length > 0) {
    // 2. Find up to 3 other posts in the same categories
    const placeholders = catIds.map(() => '?').join(',');
    const { results: sameCat } = await db
      .prepare(
        `SELECT DISTINCT p.slug, p.title, p.excerpt, p.featured_image, p.post_date, p.published_at, p.created_at
         FROM ec_posts p
         INNER JOIN content_taxonomies ct ON ct.entry_id = p.id AND ct.collection = 'posts'
         WHERE ct.taxonomy_id IN (${placeholders})
           AND p.slug != ?
           AND p.status = 'published'
           AND p.deleted_at IS NULL
         ORDER BY COALESCE(p.post_date, p.published_at, p.created_at) DESC
         LIMIT 3`
      )
      .bind(...catIds, slug!)
      .all<RelatedRow>();

    relatedPosts = sameCat;
  }

  // 3. Backfill with recent posts if fewer than 3
  if (relatedPosts.length < 3) {
    const excludeSlugs = [slug!, ...relatedPosts.map((p) => p.slug)];
    const exPlaceholders = excludeSlugs.map(() => '?').join(',');
    const needed = 3 - relatedPosts.length;
    const { results: backfill } = await db
      .prepare(
        `SELECT slug, title, excerpt, featured_image, post_date, published_at, created_at
         FROM ec_posts
         WHERE slug NOT IN (${exPlaceholders})
           AND status = 'published'
           AND deleted_at IS NULL
         ORDER BY COALESCE(post_date, published_at, created_at) DESC
         LIMIT ?`
      )
      .bind(...excludeSlugs, needed)
      .all<RelatedRow>();

    relatedPosts = [...relatedPosts, ...backfill];
  }
}

function parseRelatedImage(raw: string | null): { src: string; alt: string } | null {
  if (!raw) return null;
  try {
    const parsed = JSON.parse(raw) as { src?: string; alt?: string };
    return parsed.src ? { src: parsed.src, alt: parsed.alt ?? '' } : null;
  } catch {
    return null;
  }
}

function formatRelatedDate(val: string | null): string {
  if (!val) return '';
  return new Date(val).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

function cleanRelatedExcerpt(raw: string | null): string | null {
  if (!raw) return null;
  if (raw.includes('[vc_') || raw.includes('[/vc') || raw.startsWith('[')) return null;
  if (raw.includes('<') && raw.includes('>')) return null;
  return raw.trim() || null;
}
---

<Base title={String(data.title)} description={description}>
  {articleSchema && (
    <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  )}

  {isPost ? (
    <!-- ============ BLOG POST LAYOUT ============ -->
    <article>
      <!-- Hero -->
      <section class="bg-gray-50 py-16 dark:bg-gray-900 lg:py-24">
        <div class="mx-auto max-w-3xl px-4 lg:px-8">
          <a
            href="/learning-centre/"
            class="mb-8 inline-flex items-center gap-2 text-sm font-semibold text-primary-500 hover:text-primary-600"
          >
            ← Learning Centre
          </a>
          <h1 class="text-3xl font-normal leading-tight text-gray-900 dark:text-white sm:text-4xl lg:text-5xl">
            {data.title}
          </h1>
          {(publishedDate || authorName) && (
            <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
              {authorName && (
                <span class="flex items-center gap-1.5">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  {authorUrl ? (
                    <a href={authorUrl} class="hover:text-primary-500 hover:underline">{authorName}</a>
                  ) : authorName}
                </span>
              )}
              {publishedDate && publishedISO && (
                <span class="flex items-center gap-1.5">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <time datetime={publishedISO}>{publishedDate}</time>
                </span>
              )}
              {updatedDate && updatedISO && updatedISO !== publishedISO && (
                <span class="flex items-center gap-1.5">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                  </svg>
                  Updated <time datetime={updatedISO}>{updatedDate}</time>
                </span>
              )}
            </div>
          )}
        </div>
      </section>

      <!-- Featured image -->
      {featuredImage?.src && (
        <div class="mx-auto max-w-3xl px-4 lg:px-8">
          <div class="-mt-4 overflow-hidden rounded-2xl shadow-lg">
            <img
              src={featuredImage.src}
              alt={featuredImage.alt ?? String(data.title)}
              class="w-full object-cover"
              loading="eager"
            />
          </div>
        </div>
      )}

      <!-- Content -->
      <section class="py-12 lg:py-16">
        <div class="mx-auto max-w-3xl px-4 lg:px-8">
          <div class="prose prose-gray article-prose dark:prose-invert prose-headings:font-normal prose-a:text-primary-500 hover:prose-a:text-primary-600 prose-img:rounded-xl prose-blockquote:border-l-primary-500 prose-blockquote:not-italic prose-blockquote:text-gray-700">
            {data.content && <PortableText value={data.content} />}
          </div>
        </div>
      </section>

      <!-- Back link -->
      <div class="mx-auto max-w-3xl px-4 pb-8 lg:px-8">
        <a
          href="/learning-centre/"
          class="inline-flex items-center gap-2 rounded-full border-2 border-gray-200 px-6 py-3 text-sm font-semibold text-gray-700 transition-all hover:border-gray-300 hover:bg-gray-50 dark:border-gray-700 dark:text-gray-300 dark:hover:border-gray-600 dark:hover:bg-gray-800"
        >
          ← Back to Learning Centre
        </a>
      </div>

      <!-- Author section -->
      <div class="mx-auto max-w-3xl px-4 pb-16 lg:px-8">
        <div class="rounded-2xl border border-gray-200 bg-gray-50 p-6 dark:border-gray-700 dark:bg-gray-900">
          <div class="flex items-start gap-5">
            {authorPhoto && (
              <img
                src={authorPhoto}
                alt={authorName}
                width="200"
                height="200"
                class="h-[80px] w-[80px] flex-shrink-0 rounded-full object-cover"
                loading="lazy"
              />
            )}
            <div class="flex-1">
              <h3 class="text-xl font-semibold text-gray-900 dark:text-white">
                Hi, I'm {authorFirstName} and I wrote this article.
              </h3>
              {authorBio && (
                <div class="mt-3 space-y-2">
                  {authorBio.map((para) => (
                    <p class="text-sm italic text-gray-600 dark:text-gray-400">
                      {para.text}{para.link && (
                        <a href={para.link.href} class="font-medium text-primary-500 hover:text-primary-600 not-italic">
                          {para.link.text}
                        </a>
                      )}
                    </p>
                  ))}
                </div>
              )}
              {!authorBio && (
                <div class="mt-2">
                  <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">Written by</p>
                  {authorUrl ? (
                    <a href={authorUrl} class="mt-1 text-lg font-semibold text-gray-900 hover:text-primary-500 dark:text-white dark:hover:text-primary-400">
                      {authorName}
                    </a>
                  ) : (
                    <p class="mt-1 text-lg font-semibold text-gray-900 dark:text-white">{authorName}</p>
                  )}
                </div>
              )}
            </div>
          </div>
        </div>
      </div>

      <!-- Related reading -->
      {relatedPosts.length > 0 && (
        <section class="border-t border-gray-200 bg-gray-50 py-16 dark:border-gray-800 dark:bg-gray-900">
          <div class="mx-auto max-w-7xl px-4 lg:px-8">
            <h2 class="text-center text-2xl font-normal text-gray-900 dark:text-white sm:text-3xl">
              Keep reading
            </h2>
            <div class="mt-10 grid gap-8 sm:grid-cols-3">
              {relatedPosts.map((rp) => {
                const img = parseRelatedImage(rp.featured_image);
                const date = formatRelatedDate(rp.post_date ?? rp.published_at);
                const excerpt = cleanRelatedExcerpt(rp.excerpt);
                return (
                  <article class="group flex flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition-shadow hover:shadow-md dark:border-gray-800 dark:bg-gray-950">
                    {img && (
                      <div class="aspect-[16/9] overflow-hidden bg-gray-100 dark:bg-gray-800">
                        <img
                          src={img.src}
                          alt={img.alt || rp.title}
                          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                          loading="lazy"
                        />
                      </div>
                    )}
                    <div class="flex flex-1 flex-col p-6">
                      {date && (
                        <time class="mb-3 block text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500">
                          {date}
                        </time>
                      )}
                      <h3 class="text-lg font-normal leading-snug text-gray-900 group-hover:text-primary-500 dark:text-white dark:group-hover:text-primary-400" style="font-family: var(--font-display)">
                        <a href={`/${rp.slug}/`} class="stretched-link">
                          {rp.title}
                        </a>
                      </h3>
                      {excerpt && (
                        <p class="mt-3 flex-1 text-sm leading-relaxed text-gray-600 line-clamp-3 dark:text-gray-400">
                          {excerpt}
                        </p>
                      )}
                      <span class="mt-4 text-sm font-semibold text-primary-500">Read more →</span>
                    </div>
                  </article>
                );
              })}
            </div>
          </div>
        </section>
      )}
    </article>
  ) : (
    <!-- ============ PAGE LAYOUT ============ -->
    <article>
      <section class="bg-gray-50 py-16 dark:bg-gray-900 lg:py-24">
        <div class="mx-auto max-w-4xl px-4 lg:px-8">
          <h1 class="text-3xl font-normal leading-tight text-gray-900 dark:text-white sm:text-4xl lg:text-5xl">
            {data.title}
          </h1>
        </div>
      </section>

      {featuredImage?.src && (
        <div class="mx-auto max-w-4xl px-4 lg:px-8">
          <div class="-mt-4 overflow-hidden rounded-2xl shadow-lg">
            <img
              src={featuredImage.src}
              alt={featuredImage.alt ?? String(data.title)}
              class="w-full object-cover"
              loading="eager"
            />
          </div>
        </div>
      )}

      <section class="py-12 lg:py-16">
        <div class="mx-auto max-w-4xl px-4 lg:px-8">
          <div class="prose prose-gray max-w-none dark:prose-invert prose-headings:font-normal prose-a:text-primary-500 hover:prose-a:text-primary-600 prose-img:rounded-xl">
            {data.content && <PortableText value={data.content} />}
          </div>
        </div>
      </section>
    </article>
  )}

  <!-- CTA footer -->
  <section class="bg-gradient-to-br from-primary-500 to-accent-500 py-16">
    <div class="mx-auto max-w-3xl px-4 text-center lg:px-8">
      <h2 class="text-3xl text-white lg:text-4xl">Want results, not just reading material?</h2>
      <a
        href="/contact/"
        class="mt-8 inline-flex items-center justify-center gap-2 rounded-full bg-white px-8 py-4 text-base font-semibold text-primary-600 shadow-lg transition-all hover:bg-gray-100"
      >
        Book your free Explore Call
      </a>
    </div>
  </section>
</Base>
