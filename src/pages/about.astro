---
import Base from '@/layouts/Base.astro';
import Team from '@/components/sections/Team.astro';
import { stats, awards, site } from '@/data/site';
---

<Base title="About" description="Learn about Pixel Studio - our story, team, and what drives us.">
  <!-- Page Header -->
  <section class="bg-gray-50 py-20 dark:bg-gray-900 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl lg:text-6xl">
            We're a team of creative problem solvers
          </h1>
          <p class="mt-6 text-lg text-gray-600 dark:text-gray-400">
            Founded in 2016, {site.name} has grown from a small design studio to an award-winning
            creative agency. We're passionate about crafting digital experiences that make a difference.
          </p>
          <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
            Our team combines strategic thinking with creative excellence to help brands stand out
            in an increasingly digital world.
          </p>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] overflow-hidden rounded-2xl bg-gradient-to-br from-primary-500 to-accent-500">
            <img
              src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&h=600&fit=crop"
              alt="Our team at work"
              class="h-full w-full object-cover mix-blend-overlay"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-white py-16 dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="grid grid-cols-2 gap-8 sm:grid-cols-4">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-4xl font-bold text-primary-500 lg:text-5xl">
              {stat.value}
            </div>
            <div class="mt-2 text-sm text-gray-600 dark:text-gray-400">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="bg-white py-20 dark:bg-gray-950 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
          Our Values
        </h2>
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
          The principles that guide everything we do.
        </p>
      </div>

      <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />',
            title: 'Innovation',
            description: 'We push boundaries and explore new possibilities to create work that stands out.',
          },
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />',
            title: 'Collaboration',
            description: 'We work closely with our clients, treating every project as a true partnership.',
          },
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />',
            title: 'Excellence',
            description: 'We hold ourselves to the highest standards in everything we create.',
          },
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />',
            title: 'Reliability',
            description: 'We deliver on our promises, on time and on budget, every single time.',
          },
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />',
            title: 'Passion',
            description: 'We genuinely love what we do, and it shows in every project we deliver.',
          },
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />',
            title: 'Impact',
            description: 'We measure success by the real results we create for our clients.',
          },
        ].map((value) => (
          <div class="rounded-2xl border border-gray-200 bg-white p-8 dark:border-gray-800 dark:bg-gray-900">
            <div class="inline-flex rounded-xl bg-primary-100 p-3 text-primary-600 dark:bg-primary-900/30 dark:text-primary-400">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <Fragment set:html={value.icon} />
              </svg>
            </div>
            <h3 class="mt-4 text-lg font-bold text-gray-900 dark:text-white">{value.title}</h3>
            <p class="mt-2 text-gray-600 dark:text-gray-400">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <Team />

  <!-- Awards -->
  <section class="bg-white py-20 dark:bg-gray-950 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
          Recognition
        </h2>
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
          We're honored to be recognized by some of the industry's most prestigious awards.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {awards.map((award) => (
          <div class="rounded-xl border border-gray-200 bg-gray-50 p-6 text-center dark:border-gray-800 dark:bg-gray-900">
            <div class="text-lg font-semibold text-gray-900 dark:text-white">{award.name}</div>
            <div class="mt-1 text-sm text-primary-500">{award.year}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-br from-primary-500 to-accent-500 py-20">
    <div class="mx-auto max-w-4xl px-4 text-center lg:px-8">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        Ready to work with us?
      </h2>
      <p class="mt-4 text-lg text-white/80">
        Let's create something amazing together.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-flex items-center justify-center gap-2 rounded-full bg-white px-8 py-4 text-base font-semibold text-primary-600 shadow-lg transition-all hover:bg-gray-100"
      >
        Get in Touch
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Base>
