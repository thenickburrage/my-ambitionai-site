---
import Base from '@/layouts/Base.astro';

const publishedISO = '2026-04-13';
const updatedISO   = '2026-04-14';

const serviceSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://my-ambitionai-site.nb-e51.workers.dev/ai-review-automation/#webpage",
      "url": "https://my-ambitionai-site.nb-e51.workers.dev/ai-review-automation/",
      "name": "AI Review Automation for Service Businesses | Ambitions AI",
      "description": "Get more five-star Google reviews automatically. Personalised review request sequences by email and SMS, AI-written replies, and reputation management on autopilot. From \u00a3269/month.",
      "datePublished": publishedISO,
      "dateModified": updatedISO,
      "author": { "@id": "https://my-ambitionai-site.nb-e51.workers.dev/#nick-burrage" },
      "publisher": { "@id": "https://my-ambitionai-site.nb-e51.workers.dev/#organization" },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",                "item": "https://my-ambitionai-site.nb-e51.workers.dev/" },
          { "@type": "ListItem", "position": 2, "name": "AI Review Automation", "item": "https://my-ambitionai-site.nb-e51.workers.dev/ai-review-automation/" }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": "https://my-ambitionai-site.nb-e51.workers.dev/ai-review-automation/#service",
      "name": "AI Review Automation",
      "description": "Automated review request sequences sent by email and SMS to your customers after every service. AI-written responses to every Google review. Protection against negative reviews reaching public platforms. Full automation with zero ongoing effort.",
      "serviceType": "Review Automation",
      "url": "https://my-ambitionai-site.nb-e51.workers.dev/ai-review-automation/",
      "provider": {
        "@type": "ProfessionalService",
        "@id": "https://my-ambitionai-site.nb-e51.workers.dev/#organization",
        "name": "Ambitions AI",
        "url": "https://my-ambitionai-site.nb-e51.workers.dev"
      },
      "areaServed": [
        { "@type": "Country", "name": "United Kingdom" },
        { "@type": "Country", "name": "United States" }
      ],
      "offers": {
        "@type": "Offer",
        "price": "269",
        "priceCurrency": "GBP",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "269",
          "priceCurrency": "GBP",
          "referenceQuantity": {
            "@type": "QuantitativeValue",
            "value": "1",
            "unitCode": "MON"
          }
        },
        "availability": "https://schema.org/InStock",
        "url": "https://my-ambitionai-site.nb-e51.workers.dev/ai-review-automation/"
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://my-ambitionai-site.nb-e51.workers.dev/ai-review-automation/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much does AI review automation cost?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "\u00a3269 per month (or $340 USD). No setup fee. No contract. Cancel any time."
          }
        },
        {
          "@type": "Question",
          "name": "Which review platforms do you support?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We support all major platforms including Google, Trustpilot, Yelp, Facebook, Tripadvisor, RealSelf, Healthgrades, Zocdoc, Which?, and Houzz."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need to do anything once it is set up?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Very little. We connect directly to your CRM and run everything from there. We handle sequences, timing, replies, and ensure unhappy customer feedback reaches your team privately."
          }
        },
        {
          "@type": "Question",
          "name": "Is this service right for my business?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "If you serve customers and capture their email address or phone number, this will work for you. Around 15 customers a month is a workable minimum, though even a slower flow of fresh reviews compounds significantly over time."
          }
        },
        {
          "@type": "Question",
          "name": "Will I get any negative reviews?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our system is designed to route unhappy customers to you privately before they reach a public platform. You may still occasionally receive a negative review from someone who goes directly to Google or another platform -- but our job is to flood your profile with so many five-star reviews that your reputation speaks for itself regardless."
          }
        }
      ]
    },
    {
      "@type": "Person",
      "@id": "https://my-ambitionai-site.nb-e51.workers.dev/#nick-burrage",
      "name": "Nick Burrage",
      "url": "https://my-ambitionai-site.nb-e51.workers.dev/authors/nick-burrage/",
      "jobTitle": "Founder",
      "worksFor": { "@id": "https://my-ambitionai-site.nb-e51.workers.dev/#organization" }
    }
  ]
};
---

<Base
  title="AI Review Automation"
  metaTitle="AI Review Automation for Service Businesses | Ambitions AI"
  description="Get more five-star Google reviews automatically. Personalised review request sequences by email and SMS, AI-written replies, and reputation management on autopilot. From £269/month."
>

  <Fragment slot="head">
    <link rel="canonical" href="https://my-ambitionai-site.nb-e51.workers.dev/ai-review-automation" />
    <meta property="og:title" content="AI Review Automation for Service Businesses | Ambitions AI" />
    <meta property="og:description" content="Get more five-star Google reviews without lifting a finger. Personalised sequences, AI-written replies, and protection against negative reviews. From £269/month." />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <!-- =========================================================
       SECTION 1: HERO
  ========================================================= -->
  <section class="relative overflow-hidden bg-gray-50 dark:bg-gray-900">
    <div class="absolute inset-0 opacity-30 dark:opacity-20">
      <div class="absolute -left-8 top-0 h-96 w-96 rounded-full bg-primary-500 blur-[160px]"></div>
      <div class="absolute -right-8 bottom-0 h-96 w-96 rounded-full bg-accent-500 blur-[160px]"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 py-24 lg:px-8 lg:py-32">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary-500">AI Review Automation</p>
        <h1 class="mt-4 text-4xl font-normal leading-tight text-gray-900 dark:text-white sm:text-5xl lg:text-6xl">
          Five-star reviews that sell for you<br class="hidden sm:block" />
          <em class="italic text-primary-500">before you open your mouth.</em>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
          Automated review requests after every job. AI replies to every review. Your reputation builds itself.
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-2xl shadow-xl" data-animate>
        <img
          src="/images/review-card-04-beacon-vet.png"
          alt="Beacon Vet Care Google reviews showing five-star rating and over 500 individual reviews."
          class="w-full"
          width="1200"
        />
      </div>

      <div class="mt-10 text-center">
        <a href="#get-me-started" class="inline-flex items-center justify-center gap-2 rounded-full bg-primary-500 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-500/25 transition-all hover:bg-primary-600 hover:shadow-xl hover:shadow-primary-500/30">
          Get Me Started
        </a>
        <p class="mt-3 text-sm italic text-gray-500 dark:text-gray-400">Most clients are live within 48 hours.</p>
      </div>
    </div>
  </section>

  <!-- =========================================================
       PRICE STRIPE
  ========================================================= -->
  <div class="border-y border-gray-200 bg-white py-5 dark:border-gray-800 dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 text-center lg:px-8">
      <p class="text-lg font-semibold text-gray-900 dark:text-white">
        £269 / $340 per month. No setup fee. No contract. Cancel any time.
      </p>
    </div>
  </div>

  <!-- =========================================================
       SECTION 2: THE PROBLEM
  ========================================================= -->
  <section class="bg-white py-20 dark:bg-gray-950 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="mx-auto max-w-3xl">

        <p class="text-sm font-semibold uppercase tracking-widest text-primary-500">The Problem</p>
        <h2 class="mt-3 text-3xl font-normal text-gray-900 dark:text-white sm:text-4xl lg:text-5xl" data-animate>
          You're Losing Sales to Businesses That Aren't as Good as You.
        </h2>

        <blockquote class="mt-8 rounded-2xl border border-gray-200 bg-gray-50 px-8 py-6 dark:border-gray-800 dark:bg-gray-900" data-animate>
          <p class="text-lg italic text-gray-700 dark:text-gray-300">
            'A competitor with half our quality has twice our reviews. It is honestly maddening.'
          </p>
        </blockquote>

        <p class="mt-8 text-lg text-gray-600 dark:text-gray-400" data-animate>
          That is not a reviews problem. That is a trust problem -- and trust is what closes sales.
        </p>

        <div class="mt-8 space-y-4" data-animate>
          <div class="flex items-start gap-3">
            <span class="text-3xl font-bold text-primary-500">93%</span>
            <span class="mt-1 text-gray-600 dark:text-gray-400">of consumers say online reviews influence their purchase decision <sup class="text-primary-500"><a href="#sources">1</a></sup></span>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-3xl font-bold text-primary-500">88%</span>
            <span class="mt-1 text-gray-600 dark:text-gray-400">trust them as much as a personal recommendation from a friend <sup class="text-primary-500"><a href="#sources">2</a></sup></span>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-3xl font-bold text-primary-500">73%</span>
            <span class="mt-1 text-gray-600 dark:text-gray-400">only trust reviews left in the last month -- old reviews actively lose you sales <sup class="text-primary-500"><a href="#sources">3</a></sup></span>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-3xl font-bold text-primary-500">35%</span>
            <span class="mt-1 text-gray-600 dark:text-gray-400">more revenue earned by businesses that reply to reviews <sup class="text-primary-500"><a href="#sources">4</a></sup></span>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-3xl font-bold text-primary-500">9%</span>
            <span class="mt-1 text-gray-600 dark:text-gray-400">revenue increase from a single extra star in your rating <sup class="text-primary-500"><a href="#sources">5</a></sup></span>
          </div>
        </div>

        <div class="mt-10 text-center" data-animate>
          <a href="#get-me-started" class="inline-flex items-center justify-center gap-2 rounded-full bg-primary-500 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-500/25 transition-all hover:bg-primary-600 hover:shadow-xl hover:shadow-primary-500/30">
            Get Me Started
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- =========================================================
       SECTION 3: THE PROOF — WALL OF LOVE
  ========================================================= -->
  <section class="bg-gray-50 py-20 dark:bg-gray-900 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">

      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary-500">The Proof</p>
        <h2 class="mt-3 text-3xl font-normal text-gray-900 dark:text-white sm:text-4xl lg:text-5xl" data-animate>
          Great Reviews Don't Just Feel Good. They Build Businesses.
        </h2>
      </div>

      <div class="mx-auto mt-16 grid max-w-6xl gap-8 md:grid-cols-2 lg:grid-cols-3" data-animate>

        <!-- Card 1: Katherine Brown -->
        <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-800 overflow-hidden">
          <img
            src="/images/review-card-01-katherine-brown.png"
            alt="Katherine Brown's five-star review profile showing tripled review count."
            class="w-full"
            loading="lazy"
          />
          <div class="p-6">
            <h3 class="font-semibold text-gray-900 dark:text-white">London's Premier Window Dressing Designer</h3>
            <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
              Katherine Brown creates bespoke curtains, blinds, and window dressing for high-end London homes. Low volume, high value -- every client matters.
            </p>
            <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
              Reviews tripled in year one. As part of a wider programme with Ambitions AI, her business doubled -- reaching £1.2 million / $1.5 million in annual revenue.
            </p>
            <p class="mt-4 text-sm italic text-gray-500 dark:text-gray-400">
              "Seeing the reviews come in is an unexpected delight in my week."
            </p>
          </div>
        </div>

        <!-- Card 2: Premium Beds -->
        <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-800 overflow-hidden">
          <img
            src="/images/review-card-02-premium-beds.png"
            alt="Ultra-premium bed manufacturer's five-star Google review profile."
            class="w-full"
            loading="lazy"
          />
          <div class="p-6">
            <h3 class="font-semibold text-gray-900 dark:text-white">Ultra-Premium Bed Manufacturer, London</h3>
            <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
              Handmade beds from £30,000 to £50,000. A business built on showroom visits and word of mouth -- until now.
            </p>
            <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
              For the first time, customers are finding and buying online. Reviews were the missing trust signal that made that shift possible.
            </p>
            <p class="mt-4 text-sm italic text-gray-500 dark:text-gray-400">
              "Remembering to go back after a couple of weeks to get a review is something we frankly were never very good at. Now we can just relax and watch the reviews come in."
            </p>
          </div>
        </div>

        <!-- Card 3: Dental Practice -->
        <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-800 overflow-hidden">
          <img
            src="/images/review-card-03-dental.png"
            alt="New dental practice's five-star Google reviews showing 21 reviews in the first two weeks."
            class="w-full"
            loading="lazy"
          />
          <div class="p-6">
            <h3 class="font-semibold text-gray-900 dark:text-white">New Dental Practice, South West England</h3>
            <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
              Brand new practice. Open just two weeks. Twenty-one five-star reviews already live.
            </p>
            <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
              When you are launching a business, every review matters -- and every hour counts. This one was already building trust with new patients before the doors had barely opened.
            </p>
            <p class="mt-4 text-sm italic text-gray-500 dark:text-gray-400">
              "When you're launching a new business, there's so much to worry about. It was really nice just to watch something take care of itself for once."
            </p>
          </div>
        </div>

        <!-- Card 4: Beacon Vet Care -->
        <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-800 overflow-hidden">
          <img
            src="/images/review-card-04-beacon-vet.png"
            alt="Beacon Vet Care Google reviews showing five-star rating and over 500 individual reviews."
            class="w-full"
            loading="lazy"
          />
          <div class="p-6">
            <h3 class="font-semibold text-gray-900 dark:text-white">Beacon Vet Care -- Multiple Practices, Cornwall</h3>
            <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
              Three practices. The oldest has over 500 five-star reviews. The newest has been open just days.
            </p>
            <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
              Beacon Vet Care is growing faster than they can hire vets. Every time a new practice opens, the reputation of the others arrives first -- patients flood in before the paint is dry.
            </p>
            <p class="mt-3 text-sm font-medium text-gray-700 dark:text-gray-300">
              As far as we can find, the best-reviewed vet practice in the entire United Kingdom.
            </p>
          </div>
        </div>

        <!-- Card 5: LA Auto -->
        <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-800 overflow-hidden">
          <img
            src="/images/review-card-05-la-auto.png"
            alt="Los Angeles auto dealership Google reviews showing 4.9 star rating."
            class="w-full"
            loading="lazy"
          />
          <div class="p-6">
            <h3 class="font-semibold text-gray-900 dark:text-white">Used Car Dealership, Los Angeles</h3>
            <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
              One of the toughest markets there is. Budget car buyers are hard to please, and the sector has a trust problem that goes back decades.
            </p>
            <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
              This dealership had a difficult period that had dragged their rating down to 4.3. They fixed the service. We fixed the reputation. They are now sitting at 4.9 stars -- and in a Los Angeles market where most competitors struggle to hold 4.0, that is a genuine commercial advantage.
            </p>
            <p class="mt-3 text-sm font-medium text-gray-700 dark:text-gray-300">
              In a business where trust is everything and scepticism runs deep, they are now the obvious choice.
            </p>
          </div>
        </div>

      </div>

      <p class="mx-auto mt-10 max-w-3xl text-center text-gray-600 dark:text-gray-400" data-animate>
        You can look them up. The reviews speak for themselves.
      </p>

    </div>
  </section>

  <!-- =========================================================
       BILTONG CALLOUT
  ========================================================= -->
  <section class="bg-white py-16 dark:bg-gray-950">
    <div class="mx-auto max-w-3xl px-4 lg:px-8">
      <div class="rounded-2xl border-2 border-primary-200 bg-primary-50 p-8 dark:border-primary-800 dark:bg-primary-900/20" data-animate>
        <p class="text-xl font-semibold text-gray-900 dark:text-white">
          One email to 3,000 past customers. £1,200 in sales. Same day.
        </p>
        <p class="mt-4 text-gray-600 dark:text-gray-400">
          A Biltong e-commerce client had never asked their customers for a review. We sent one email sequence to their entire customer base. The reviews came in -- and so did the orders. A review request is also a reminder that you exist.
        </p>
        <div class="mt-6">
          <a href="#get-me-started" class="inline-flex items-center justify-center gap-2 rounded-full bg-primary-500 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-500/25 transition-all hover:bg-primary-600 hover:shadow-xl hover:shadow-primary-500/30">
            Get Me Started
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================================
       GYM CALLOUT
  ========================================================= -->
  <section class="bg-gray-50 py-16 dark:bg-gray-900">
    <div class="mx-auto max-w-3xl px-4 lg:px-8">
      <div class="text-center" data-animate>
        <h3 class="text-2xl font-normal text-gray-900 dark:text-white">I even did it for my own gym.</h3>
        <p class="mt-2 text-gray-600 dark:text-gray-400">Here I am in the review. Slightly sweaty. Very happy with the service.</p>
      </div>

      <div class="mx-auto mt-8 max-w-lg overflow-hidden rounded-2xl shadow-lg" data-animate>
        <img
          src="/images/review-nick-gym.png"
          alt="Nick Burrage's five-star review of his own gym, showing the review automation system in action."
          class="w-full"
          loading="lazy"
        />
      </div>

      <div class="mt-8 text-center" data-animate>
        <p class="italic text-gray-600 dark:text-gray-400">
          My fellow members are now used to me pestering them to leave a review mid-workout. We have the most reviews in town. And yes, we are five-star.
        </p>
        <p class="mt-4 italic text-gray-600 dark:text-gray-400">
          If I trust this system enough to use it on a business I actually go to, that probably tells you something.
        </p>
      </div>
    </div>
  </section>

  <!-- =========================================================
       SECTION 4: HOW YOU GET YOUR REVIEW MACHINE
  ========================================================= -->
  <section class="bg-white py-20 dark:bg-gray-950 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="mx-auto max-w-3xl text-center" data-animate>
        <p class="text-sm font-semibold uppercase tracking-widest text-primary-500">How It Works</p>
        <h2 class="mt-3 text-3xl font-normal text-gray-900 dark:text-white sm:text-4xl lg:text-5xl">
          How You Get Your Review Machine.
        </h2>
      </div>

      <!-- Video placeholder -->
      <div class="mx-auto mt-12 max-w-3xl" data-animate>
        <div class="flex aspect-video items-center justify-center rounded-2xl border-2 border-dashed border-gray-300 bg-gray-100 dark:border-gray-700 dark:bg-gray-800">
          <div class="text-center">
            <svg class="mx-auto h-16 w-16 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z" />
            </svg>
            <p class="mt-4 text-sm text-gray-500 dark:text-gray-400">Video coming soon</p>
          </div>
        </div>
      </div>

      <div class="mt-16 grid gap-8 sm:grid-cols-3" data-animate>
        <div class="relative rounded-2xl border border-gray-200 bg-white p-8 dark:border-gray-800 dark:bg-gray-800">
          <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-full bg-primary-500 text-xl font-bold text-white">1</div>
          <h3 class="text-xl font-normal text-gray-900 dark:text-white">Share Your Details</h3>
          <p class="mt-3 text-gray-600 dark:text-gray-400">Paste your review platform link and hit Get Me Started.</p>
        </div>
        <div class="relative rounded-2xl border border-gray-200 bg-white p-8 dark:border-gray-800 dark:bg-gray-800">
          <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-full bg-primary-500 text-xl font-bold text-white">2</div>
          <h3 class="text-xl font-normal text-gray-900 dark:text-white">We Build Everything</h3>
          <p class="mt-3 text-gray-600 dark:text-gray-400">We connect to your CRM, write every message, and configure the whole system. You approve before anything goes out.</p>
        </div>
        <div class="relative rounded-2xl border border-gray-200 bg-white p-8 dark:border-gray-800 dark:bg-gray-800">
          <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-full bg-primary-500 text-xl font-bold text-white">3</div>
          <h3 class="text-xl font-normal text-gray-900 dark:text-white">Your Review Machine Goes Live</h3>
          <p class="mt-3 text-gray-600 dark:text-gray-400">Reviews arrive. Trust builds. Sales conversations get easier. You stop losing business to competitors with worse services and better profiles.</p>
        </div>
      </div>

      <div class="mx-auto mt-8 max-w-3xl text-center" data-animate>
        <p class="text-lg text-gray-600 dark:text-gray-400">No sales call. No pitch. Everything you need to decide is on this page. Most clients just get started.</p>
      </div>

      <div class="mt-10 text-center" data-animate>
        <a href="#get-me-started" class="inline-flex items-center justify-center gap-2 rounded-full bg-primary-500 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-500/25 transition-all hover:bg-primary-600 hover:shadow-xl hover:shadow-primary-500/30">
          Get Me Started
        </a>
      </div>
    </div>
