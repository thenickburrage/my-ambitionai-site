---
import Base from '@/layouts/Base.astro';

const publishedISO = '2026-04-17';
const updatedISO   = '2026-04-17';

const serviceSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://theambitionsagency.com/ai-voice-agent/#webpage",
      "url": "https://theambitionsagency.com/ai-voice-agent/",
      "name": "AI Voice Agent for Sales and Service | Ambitions AI",
      "description": "Answer every lead in seconds. Handle every inbound call 24/7. Turn every website visitor into a buyer. AI voice and chat for service businesses. From £2,500/month.",
      "datePublished": publishedISO,
      "dateModified": updatedISO,
      "author": { "@id": "https://theambitionsagency.com/#nick-burrage" },
      "publisher": { "@id": "https://theambitionsagency.com/#organization" },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",           "item": "https://theambitionsagency.com/" },
          { "@type": "ListItem", "position": 2, "name": "AI Voice Agent", "item": "https://theambitionsagency.com/ai-voice-agent/" }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": "https://theambitionsagency.com/ai-voice-agent/#service",
      "name": "AI Voice Agent",
      "alternateName": ["AI Sales and Service Engine", "AI Voice Systems", "AI Automations"],
      "description": "AI voice and chat systems for service businesses. Outbound voice agents that call every inbound lead within seconds. Inbound voice receptionists that handle routine calls around the clock. Intelligent on-page chatbots that qualify and convert website visitors. Integrated with your CRM, monitored weekly, and refined continuously.",
      "serviceType": "AI Voice and Chat Automation",
      "url": "https://theambitionsagency.com/ai-voice-agent/",
      "provider": {
        "@type": "ProfessionalService",
        "@id": "https://theambitionsagency.com/#organization",
        "name": "Ambitions AI",
        "url": "https://theambitionsagency.com"
      },
      "areaServed": [
        { "@type": "Country", "name": "United Kingdom" },
        { "@type": "Country", "name": "United States" }
      ],
      "offers": {
        "@type": "Offer",
        "priceSpecification": {
          "@type": "PriceSpecification",
          "minPrice": "2500",
          "priceCurrency": "GBP",
          "description": "Monthly AI voice and chat system"
        },
        "availability": "https://schema.org/InStock",
        "url": "https://theambitionsagency.com/pricing/"
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://theambitionsagency.com/ai-voice-agent/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much does an AI voice system cost?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The full system, speed-to-lead voice agent, 24-hour voice receptionist, and on-page AI chatbot, is \u00a32,500 per month (or $3,150 USD). Individual elements are available separately at lower cost. No setup fee. No long contract. Very high outbound call volume adds telephony costs of roughly \u00a3500 to \u00a3750 per month on top."
          }
        },
        {
          "@type": "Question",
          "name": "How long does setup take?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Typically around ten days. More complex CRM integrations can take a little longer. We write the scripts, train the voice on your business, connect your systems, and test every conversation in private before a single real call happens."
          }
        },
        {
          "@type": "Question",
          "name": "Will callers know they are speaking to an AI?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We are always upfront. The AI introduces itself honestly. In our experience, callers rarely mind once they discover how quickly and efficiently their question gets answered. If a caller wants to speak to a human, they are transferred straight through during office hours."
          }
        },
        {
          "@type": "Question",
          "name": "What happens outside office hours?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The voice receptionist handles routine questions, bookings, and rescheduling around the clock. The speed-to-lead agent either calls the lead immediately, or at the start of the next office hours, depending on how you want to run it. Your diary fills while you sleep."
          }
        },
        {
          "@type": "Question",
          "name": "Which CRMs do you integrate with?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most mainstream CRMs including HubSpot, Salesforce, Pipedrive, Zoho, Go High Level, and many industry-specific systems. If yours is unusual, we check the integration during the Explore Call before anyone commits to anything."
          }
        },
        {
          "@type": "Question",
          "name": "Is this right for every business?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "It needs volume to earn its keep. A busy sales function, a busy service function, or both. A handful of leads a week will not yet justify the full system, though the on-page chatbot works at much lower volumes and is often a good starting point."
          }
        }
      ]
    },
    {
      "@type": "Person",
      "@id": "https://theambitionsagency.com/#nick-burrage",
      "name": "Nick Burrage",
      "url": "https://theambitionsagency.com/authors/nick-burrage/",
      "jobTitle": "Founder",
      "worksFor": { "@id": "https://theambitionsagency.com/#organization" }
    }
  ]
};
---

<Base
  title="AI Voice Agent"
  metaTitle="AI Voice Agent for Sales and Service | Ambitions AI"
  description="Answer every lead in seconds. Handle every inbound call 24/7. Turn every website visitor into a buyer. AI voice and chat for service businesses. From £2,500/month."
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <meta property="og:title" content="AI Voice Agent for Sales and Service | Ambitions AI" />
    <meta property="og:description" content="Every lead called in seconds. Every inbound call answered. Every website visitor engaged. 24/7 AI voice and chat systems for service businesses." />
  </Fragment>

  <!-- =========================================================
       HERO
  ========================================================= -->
  <section class="relative overflow-hidden bg-gray-50 dark:bg-gray-900">
    <div class="absolute inset-0 opacity-30 dark:opacity-20">
      <div class="absolute -left-8 top-0 h-96 w-96 rounded-full bg-primary-500 blur-[160px]"></div>
      <div class="absolute -right-8 bottom-0 h-96 w-96 rounded-full bg-accent-500 blur-[160px]"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 py-24 lg:px-8 lg:py-32">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-gray-500 dark:text-gray-400">AI Voice Agent</p>
        <h1 class="mt-4 text-4xl font-normal leading-tight text-gray-900 dark:text-white sm:text-5xl lg:text-6xl">
          Answer Every Lead in Seconds.<br class="hidden sm:block" />
          <em class="italic text-primary-500">With an AI Voice Agent That Never Sleeps.</em>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
          Outbound calls, inbound calls, and intelligent on-page chat. One connected system. Often live within ten days. No setup fee.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-primary-500 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-500/25 transition-all hover:bg-primary-600 hover:shadow-xl hover:shadow-primary-500/30"
          >
            Start Now →
          </a>
          <a
            href="#how-it-works"
            class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-gray-300 bg-white px-8 py-4 text-base font-semibold text-gray-700 transition-all hover:border-gray-400 hover:bg-gray-50 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-300 dark:hover:border-gray-600 dark:hover:bg-gray-700"
          >
            See How It Works
          </a>
        </div>
      </div>

      <!-- Hero image placeholder -->
      <div class="mx-auto mt-16 max-w-2xl" data-animate>
        <div class="flex aspect-[16/9] items-center justify-center overflow-hidden rounded-2xl bg-gray-200 shadow-2xl dark:bg-gray-800">
          <div class="text-center">
            <div class="mx-auto mb-3 flex h-14 w-14 items-center justify-center rounded-full bg-gray-300 dark:bg-gray-700">
              <svg class="h-7 w-7 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
              </svg>
            </div>
            <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Hero visual</p>
            <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">Image coming soon</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Author credit -->
  <div class="border-b border-gray-200 bg-white py-4 dark:border-gray-800 dark:bg-gray-950">
    <div class="mx-auto flex max-w-7xl items-center justify-center gap-6 px-4 text-sm text-gray-400 dark:text-gray-500 lg:px-8">
      <span class="flex items-center gap-1.5">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
        </svg>
        Nick Burrage
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 9v7.5" />
        </svg>
        17 April 2026
      </span>
    </div>
  </div>

  <!-- =========================================================
       SECTION 2: THE PROBLEM
  ========================================================= -->
  <section class="bg-white py-20 dark:bg-gray-950 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="mx-auto max-w-3xl">

        <p class="text-sm font-semibold uppercase tracking-widest text-gray-500 dark:text-gray-400">The Problem</p>
        <h2 class="mt-3 text-3xl font-normal text-gray-900 dark:text-white sm:text-4xl lg:text-5xl" data-animate>
          The Sale Goes to Whoever Picks Up the Phone First. Not the Best. Not the Cheapest.
        </h2>

        <div class="mt-12 space-y-6" data-animate>
          <blockquote class="relative rounded-2xl border border-gray-200 bg-gray-50 px-8 py-6 dark:border-gray-800 dark:bg-gray-900">
            <svg class="absolute left-8 top-6 h-6 w-6 text-gray-300 dark:text-gray-700" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
            <p class="pl-8 text-lg italic text-gray-700 dark:text-gray-300">'We know the leads are coming in. We just can't get to them all fast enough.'</p>
          </blockquote>
          <blockquote class="relative rounded-2xl border border-gray-200 bg-gray-50 px-8 py-6 dark:border-gray-800 dark:bg-gray-900">
            <svg class="absolute left-8 top-6 h-6 w-6 text-gray-300 dark:text-gray-700" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
            <p class="pl-8 text-lg italic text-gray-700 dark:text-gray-300">'By the time we call back, half of them have already gone elsewhere.'</p>
          </blockquote>
          <blockquote class="relative rounded-2xl border border-gray-200 bg-gray-50 px-8 py-6 dark:border-gray-800 dark:bg-gray-900">
            <svg class="absolute left-8 top-6 h-6 w-6 text-gray-300 dark:text-gray-700" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
            <p class="pl-8 text-lg italic text-gray-700 dark:text-gray-300">'Reception is drowning. Most of the calls are just opening hours and directions anyway.'</p>
          </blockquote>
        </div>

        <div class="prose dark:prose mt-10 max-w-none" data-animate>
          <p>Those are three different sentences. They are the same problem.</p>
          <p>It's 7.43pm on a Thursday. A lead fills in your form. Your team are at home with their families, where they should be.</p>
          <p>The lead waits.</p>
          <p>At 7.46pm, they fill in a form on one of your competitors' websites too. Just in case.</p>
          <p>By 9.15am on Friday, when you finally spot the enquiry, the competitor has already called. Twice. Booked an appointment. Closed the sale.</p>
          <p>You never even knew that lead was there.</p>
          <p>This is not a feeling. It is documented, repeatable research. Harvard Business Review found that businesses who respond to a new lead within an hour are nearly seven times more likely to have a real conversation with that buyer than those who respond even an hour later. Wait twenty-four hours and you are sixty times less likely.</p>
        </div>

        <!-- Dominant pull-out -->
        <div class="mt-10 rounded-2xl bg-gray-900 p-8 text-white shadow-2xl" data-animate>
          <p class="text-xl font-semibold sm:text-2xl">You are not competing on quality. You are competing on speed. And right now, you are losing.</p>
        </div>

        <div class="mt-10 text-center" data-animate>
          <a href="/contact" class="inline-flex items-center justify-center gap-2 rounded-full bg-primary-500 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-500/25 transition-all hover:bg-primary-600 hover:shadow-xl hover:shadow-primary-500/30">
            Start Now →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- =========================================================
       SECTION 3: THE FLIP
  ========================================================= -->
  <section class="bg-gray-50 py-24 dark:bg-gray-900 lg:py-32">
    <div class="mx-auto max-w-4xl px-4 text-center lg:px-8">
      <h2 class="text-3xl font-normal leading-tight text-gray-900 dark:text-white sm:text-4xl lg:text-5xl" data-animate>
        You Deserve Every Buyer and Every Customer<br class="hidden sm:block" />
        <em class="italic text-primary-500">to Meet a Warm, Smart, Helpful Voice. At Any Hour of Any Day.</em>
      </h2>
    </div>
  </section>

  <!-- =========================================================
       SECTION 4: WHAT IT DOES
  ========================================================= -->
  <section class="bg-white py-20 dark:bg-gray-950 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="mx-auto max-w-3xl">

        <p class="text-sm font-semibold uppercase tracking-widest text-gray-500 dark:text-gray-400">What It Does</p>
        <h2 class="mt-3 text-3xl font-normal text-gray-900 dark:text-white sm:text-4xl lg:text-5xl" data-animate>
          Catch Every Lead. Book Every Caller. Convert Every Visitor.
        </h2>
        <div class="prose dark:prose mt-8 max-w-none" data-animate>
          <p>Three capabilities. You might take one. You might take all three. Each one solves a different problem. Together they close every gap in your sales and service at once.</p>
          <p>Here is how each one works.</p>
        </div>

        <!-- ===== SPEED-TO-LEAD ===== -->
        <div class="mt-16 border-t border-gray-200 pt-12 dark:border-gray-800" data-animate>
          <p class="text-sm font-bold uppercase tracking-widest text-indigo-600 dark:text-indigo-400">Speed-to-Lead AI Voice Agent</p>
          <h3 class="mt-4 text-2xl font-normal text-gray-900 dark:text-white sm:text-3xl">Catch Every Hot Lead. Before It Cools.</h3>

          <div class="prose dark:prose mt-6 max-w-none">
            <p>The moment someone fills in a form, replies to an ad, or clicks a campaign link, the system calls them. Not in an hour. Not in ten minutes. In seconds.</p>
          </div>

          <h4 class="mt-8 text-lg font-semibold text-gray-900 dark:text-white">Your Buyer Is Also Looking at Three of Your Competitors.</h4>
          <p class="mt-3 text-gray-600 dark:text-gray-400">Modern buyers shortlist in bulk. Your form is one of three or four they will fill in. Once they have, they go with whoever gets back to them first. Where services are broadly comparable, it is nearly always speed that wins.</p>

          <h4 class="mt-8 text-lg font-semibold text-gray-900 dark:text-white">An Instant Call. A Warm Conversation. An Appointment, Where Possible, Booked on the Spot.</h4>
          <p class="mt-3 text-gray-600 dark:text-gray-400">The system rings while the interest is still hot. It runs a warm, engaging conversation. It asks the right qualifying questions. It listens. It responds. And wherever possible, it books the buyer straight into the diary, closing the moment while the moment is live. The unqualified callers are handled politely and removed from your team's day. The real buyers get transferred straight through to a human, already warmed up and leaning in.</p>

          <h4 class="mt-8 text-lg font-semibold text-gray-900 dark:text-white">120 Responses a Day. Every One Called Within Seconds.</h4>
          <p class="mt-3 text-gray-600 dark:text-gray-400">A Los Angeles car dealership runs adverts aimed at buyers who struggle to get finance elsewhere. On a busy day, that is 120 form responses. A proportion of those are bots. Another proportion are people nowhere near ready to buy. In the middle sit the genuine, motivated buyers, the ones who change a business month.</p>

          <h4 class="mt-8 text-lg font-semibold text-gray-900 dark:text-white">No More Bots. No More Voicemails. Just Buyers.</h4>
          <p class="mt-3 text-gray-600 dark:text-gray-400">Before the voice agent, their sales team waded through every response by hand. Now the agent calls every single enquiry within seconds, runs the qualification, and only forwards the real prospects. The team no longer dials voicemails, dead numbers, and bots. Their staffing has naturally reduced, because every remaining salesperson is now talking only to people who want to buy.</p>

          <h4 class="mt-8 text-lg font-semibold text-gray-900 dark:text-white">Same Pattern, the Other Side of the Atlantic.</h4>
          <p class="mt-3 text-gray-600 dark:text-gray-400">A UK sporting organisation whose customers book football pitches runs an almost identical system. Instant response, warm qualification, warm handover to a human for the booking itself.</p>

          <!-- Audio placeholder -->
          <div class="mt-8 flex items-center gap-4 rounded-2xl border border-gray-200 bg-gray-50 p-6 dark:border-gray-800 dark:bg-gray-900">
            <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-indigo-100 dark:bg-indigo-900/30">
              <svg class="h-6 w-6 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-900 dark:text-white">Outbound voice agent sample</p>
              <p class="text-xs text-gray-500 dark:text-gray-400">Audio recording coming soon</p>
            </div>
          </div>

          <div class="mt-8 rounded-xl border-l-4 border-indigo-500 bg-indigo-50 pl-6 py-4 dark:bg-indigo-900/10">
            <p class="italic text-gray-700 dark:text-gray-300">Your sales team stops dialling bots. They start talking to buyers already leaning in.</p>
          </div>
        </div>

        <!-- ===== 24-HOUR RECEPTIONIST ===== -->
        <div class="mt-16 border-t border-gray-200 pt-12 dark:border-gray-800" data-animate>
          <p class="text-sm font-bold uppercase tracking-widest text-indigo-600 dark:text-indigo-400">24-Hour AI Voice Receptionist</p>
          <h3 class="mt-4 text-2xl font-normal text-gray-900 dark:text-white sm:text-3xl">Appointments Booked at Midnight. Diaries Full by Morning.</h3>

          <div class="prose dark:prose mt-6 max-w-none">
            <p>Most service businesses have a reception team drowning in the same twenty questions on repeat. Opening hours. Directions. Prices. Joining procedures. Every one of those calls swallows a minute of staff time, and every one of them leaves a genuine buyer on hold.</p>
            <p>That is only half the problem. The other half is worse.</p>
          </div>

          <h4 class="mt-8 text-lg font-semibold text-gray-900 dark:text-white">Your Busiest Booking Hours Are the Hours You're Not Open.</h4>
          <p class="mt-3 text-gray-600 dark:text-gray-400">The moment a prospective customer is most likely to pick up the phone is rarely between nine and five. It is Tuesday evening on the sofa, after the children are in bed. It is Sunday morning over coffee. It is Friday night after dinner. That is when people make decisions, because that is when they have the headspace.</p>
          <p class="mt-3 text-gray-600 dark:text-gray-400">That is also when your team are at home, where they should be. So those calls go unanswered. The customer waits until Monday. By then, someone else has picked up.</p>

          <h4 class="mt-8 text-lg font-semibold text-gray-900 dark:text-white">No Stack of Messages Waiting at Nine in the Morning.</h4>
          <p class="mt-3 text-gray-600 dark:text-gray-400">Your reception team start their Monday helping the people standing in front of them. Not working through a backlog of voicemails left over the weekend. Not apologising to buyers who have already gone somewhere else. The diary is already filling. The day is already moving.</p>

          <h4 class="mt-8 text-lg font-semibold text-gray-900 dark:text-white">When Plans Change, the System Handles It.</h4>
          <p class="mt-3 text-gray-600 dark:text-gray-400">Customers who need to reschedule, cancel, or move an appointment are answered politely, 24 hours a day. No gaps appear in the diary because nobody was there to rebook the slot. Nobody double-books because the system didn't know.</p>

          <h4 class="mt-8 text-lg font-semibold text-gray-900 dark:text-white">Up to 4,000 Calls a Month. Two-Thirds Handled Instantly.</h4>
          <p class="mt-3 text-gray-600 dark:text-gray-400">A UK chain of gyms and fitness centres takes between 3,000 and 4,000 calls a month. Between 60 and 70 per cent of those are routine information questions. The AI handles them instantly, day and night.</p>

          <h4 class="mt-8 text-lg font-semibold text-gray-900 dark:text-white">Reception Back on the Gym Floor. Members Served Around the Clock.</h4>
          <p class="mt-3 text-gray-600 dark:text-gray-400">The reception team get their time back to serve the members actually standing in front of them. Members still get answers, even at ten past midnight. Nobody loses.</p>

          <!-- Audio placeholder -->
          <div class="mt-8 flex items-center gap-4 rounded-2xl border border-gray-200 bg-gray-50 p-6 dark:border-gray-800 dark:bg-gray-900">
