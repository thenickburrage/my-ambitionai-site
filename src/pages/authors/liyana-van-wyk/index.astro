---
import { env } from 'cloudflare:workers';
import Base from '@/layouts/Base.astro';

const db = env.DB as D1Database;

type PostRow = {
  id: string;
  slug: string;
  title: string;
  excerpt: string | null;
  post_date: string | null;
  published_at: string | null;
  created_at: string;
};

const { results: posts } = await db
  .prepare(
    `SELECT p.id, p.slug, p.title, p.excerpt, p.post_date, p.published_at, p.created_at
     FROM ec_posts p
     INNER JOIN _emdash_content_bylines cb ON cb.content_id = p.id
     INNER JOIN _emdash_bylines b ON b.id = cb.byline_id
     WHERE p.status = 'published'
       AND p.deleted_at IS NULL
       AND b.slug = 'liyana-van-wyk'
     ORDER BY COALESCE(p.post_date, p.published_at, p.created_at) DESC
     LIMIT 12`
  )
  .all<PostRow>();

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfilePage",
      "@id": "https://theambitionsagency.com/authors/liyana-van-wyk/#webpage",
      "url": "https://theambitionsagency.com/authors/liyana-van-wyk/",
      "name": "Liyana van Wyk — Technical SEO & AEO Lead | Ambitions AI",
      "description": "Liyana van Wyk leads the technical SEO and AEO team at Ambitions AI. 15+ years in digital marketing, Google and HubSpot certified, based in South Africa.",
      "mainEntity": { "@id": "https://theambitionsagency.com/#liyana-van-wyk" }
    },
    {
      "@type": "Person",
      "@id": "https://theambitionsagency.com/#liyana-van-wyk",
      "name": "Liyana van Wyk",
      "url": "https://theambitionsagency.com/authors/liyana-van-wyk/",
      "jobTitle": "Technical SEO & AEO Lead",
      "worksFor": { "@id": "https://theambitionsagency.com/#organization" },
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "ZA"
      },
      "sameAs": [
        "https://www.linkedin.com/in/iamliyanav/"
      ],
      "knowsAbout": [
        "Technical SEO", "AEO", "GEO", "Google Ads", "Google Analytics 4",
        "Search Console", "Meta Ads", "HubSpot", "Digital Marketing Strategy", "CRM Automation"
      ],
      "hasCredential": [
        { "@type": "EducationalOccupationalCredential", "name": "Google Ads Certification", "credentialCategory": "certification" },
        { "@type": "EducationalOccupationalCredential", "name": "Google Analytics 4 Certification", "credentialCategory": "certification" },
        { "@type": "EducationalOccupationalCredential", "name": "HubSpot Digital Marketing Certification", "credentialCategory": "certification" },
        { "@type": "EducationalOccupationalCredential", "name": "Meta Business Platform Certification", "credentialCategory": "certification" },
        { "@type": "EducationalOccupationalCredential", "name": "Advanced Diploma in Psychology", "credentialCategory": "degree" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://theambitionsagency.com/#organization",
      "name": "Ambitions AI",
      "url": "https://theambitionsagency.com"
    }
  ]
};
---

<Base
  title="Liyana van Wyk"
  metaTitle="Liyana van Wyk — Technical SEO & AEO Lead | Ambitions AI"
  description="Liyana van Wyk leads the technical SEO and AEO team at Ambitions AI. 15 years of experience, Google and HubSpot certified, and based in South Africa."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <!-- =========================================================
       AUTHOR HEADER
  ========================================================= -->
  <section class="relative overflow-hidden bg-gray-900">
    <div class="absolute inset-0 opacity-40">
      <div class="absolute -right-8 top-0 h-96 w-96 rounded-full bg-teal-600 blur-[160px]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 py-20 lg:px-8 lg:py-28">
      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">

        <div>
          <p class="text-sm font-semibold uppercase tracking-widest text-gray-400">Author</p>
          <h1 class="mt-3 text-4xl font-normal text-white sm:text-5xl">Liyana van Wyk</h1>
          <p class="mt-2 text-lg text-teal-400">Technical SEO &amp; AEO Lead, Ambitions AI</p>
          <p class="mt-6 text-gray-300 lg:text-lg">
            15 years in digital marketing. An extraordinary list of qualifications. The technical backbone of everything we do on search.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="https://www.linkedin.com/in/iamliyanav/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full border border-gray-600 bg-gray-800 px-5 py-2.5 text-sm font-medium text-gray-200 transition-all hover:border-teal-500 hover:text-teal-400"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 23.997 23.227 23.997 22.271V1.729C23.997.774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
            <a
              href="/contact"
              class="inline-flex items-center gap-2 rounded-full bg-teal-600 px-5 py-2.5 text-sm font-semibold text-white transition-all hover:bg-teal-700"
            >
              Work with Liyana →
            </a>
          </div>
        </div>

        <div class="overflow-hidden rounded-2xl shadow-2xl">
          <img
            src="/images/LIYANA_AUTHOR.webp"
            alt="Liyana van Wyk, Technical SEO & AEO Lead at Ambitions AI"
            class="w-full object-cover"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- =========================================================
       BIO
  ========================================================= -->
  <section class="bg-white py-20 dark:bg-gray-950 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-3 lg:gap-16">

        <div class="lg:col-span-2 space-y-8" data-animate>
          <div class="prose dark:prose max-w-none">
            <p>If you have ever been on a Zoom call with Liyana, you will know two things immediately. First, there is almost always a smile on her face. Second, there is usually a glimpse of the South African coast through the window behind her, which, wherever you are in the world, is either delightful or deeply unfair depending on your mood.</p>
            <p>Liyana leads the technical SEO and AEO team at Ambitions AI. She has been working in digital marketing for over 15 years, and in that time she has built a level of technical knowledge that is, frankly, rare. She does not just understand the theory. She goes away and studies it, tests it, and comes back with answers. Her certification list alone is longer than most people's CVs.</p>
            <p>She works with clients across the UK, the USA, and beyond. At Ambitions AI, Liyana works alongside her husband Wes, and together they lead a wider team of technical specialists covering SEO, AEO, and everything in between. They are the backbone of what we do on the technical side of the business, and clients feel the difference immediately.</p>
            <p>When she is not deep in a Search Console audit or mapping out an AEO strategy, she is at home in South Africa keeping up with three teenagers who have a habit of disappearing out of the back door and heading straight for the sea. We understand completely.</p>
          </div>
        </div>

        <!-- Qualifications sidebar -->
        <div data-animate>
          <div class="rounded-2xl border border-gray-200 bg-gray-50 p-6 dark:border-gray-800 dark:bg-gray-900">
            <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500">Qualifications</h2>
            <ul class="mt-4 space-y-3">
              {[
                'Google Ads Certified (Search, Display, Video, Shopping, Apps, Measurement)',
                'Google Analytics 4 (GA4) Certified',
                'HubSpot Certified: Digital Marketing, Content Marketing, Social Media, Email Marketing, Growth-Driven Design',
                'Meta Business Platform: Ads, Commerce Management, Business Marketing Strategy',
                'Advanced Diploma in Psychology (Distinction)',
                'Diploma in Cognitive Behavioural Therapy (Distinction)',
                '15+ years in SEO, AEO, GEO and paid search strategy',
              ].map((qual) => (
                <li class="flex items-start gap-2 text-sm">
                  <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-teal-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-gray-700 dark:text-gray-300">{qual}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- =========================================================
       ARTICLES BY LIYANA
  ========================================================= -->
  <section class="bg-gray-50 py-20 dark:bg-gray-900 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <h2 class="text-3xl font-normal text-gray-900 dark:text-white sm:text-4xl" data-animate>
        Articles by Liyana
      </h2>

      {posts.length > 0 ? (
        <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3" data-animate>
          {posts.map((post) => {
            const date = post.post_date ?? post.published_at ?? post.created_at;
            const formatted = date
              ? new Date(date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
              : null;
            return (
              <a href={`/${post.slug}/`} class="group rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:shadow-md dark:border-gray-800 dark:bg-gray-800">
                {formatted && <p class="text-xs text-gray-400 dark:text-gray-500">{formatted}</p>}
                <h3 class="mt-2 font-semibold text-gray-900 group-hover:text-teal-600 dark:text-white dark:group-hover:text-teal-400 transition-colors">
                  {post.title}
                </h3>
                {post.excerpt && (
                  <p class="mt-2 text-sm text-gray-600 line-clamp-3 dark:text-gray-400">{post.excerpt}</p>
                )}
                <span class="mt-4 inline-block text-sm font-medium text-teal-600 dark:text-teal-400">Read more →</span>
              </a>
            );
          })}
        </div>
      ) : (
        <p class="mt-8 text-gray-500 dark:text-gray-400" data-animate>Articles coming soon.</p>
      )}
    </div>
  </section>

</Base>
