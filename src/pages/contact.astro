---
import Base from '@/layouts/Base.astro';
import Contact from '@/components/sections/Contact.astro';
---

<Base title="Contact" description="Get in touch to start your next project with us.">
  <Contact
    title="Get in Touch"
    subtitle="Ready to start your next project? Have questions about our services? We'd love to hear from you. Fill out the form below or reach out directly."
  />

  <!-- Map Section (placeholder) -->
  <section class="bg-gray-100 dark:bg-gray-900">
    <div class="mx-auto max-w-7xl px-4 py-16 lg:px-8">
      <div class="aspect-[2/1] overflow-hidden rounded-2xl bg-gray-200 dark:bg-gray-800">
        <div class="flex h-full items-center justify-center">
          <div class="text-center">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="mt-4 text-gray-500 dark:text-gray-400">
              Map placeholder - integrate your preferred map service
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="bg-white py-20 dark:bg-gray-950 lg:py-28">
    <div class="mx-auto max-w-4xl px-4 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
          Frequently Asked Questions
        </h2>
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
          Quick answers to questions you might have.
        </p>
      </div>

      <div class="mt-12 divide-y divide-gray-200 dark:divide-gray-800">
        {[
          {
            question: 'What is your typical project timeline?',
            answer: 'Project timelines vary based on scope and complexity. A typical branding project takes 4-6 weeks, while a full website design and development project can take 8-12 weeks. We\'ll provide a detailed timeline during our initial consultation.',
          },
          {
            question: 'How do you handle project pricing?',
            answer: 'We provide custom quotes based on each project\'s specific requirements. After our discovery call, we\'ll send a detailed proposal outlining scope, timeline, and investment. We offer flexible payment terms to accommodate different budgets.',
          },
          {
            question: 'Do you work with clients remotely?',
            answer: 'Absolutely! While we\'re based in Los Angeles, we work with clients worldwide. We use video calls, collaborative tools, and regular check-ins to ensure seamless communication regardless of location.',
          },
          {
            question: 'What\'s included in your web design service?',
            answer: 'Our web design service includes strategy and planning, wireframing, visual design, responsive development, content integration, SEO optimization, and training on how to manage your new site.',
          },
          {
            question: 'Do you offer ongoing support after launch?',
            answer: 'Yes! We offer various support packages including maintenance, hosting, content updates, and ongoing optimization. Many of our clients choose to work with us on a retainer basis for continued growth.',
          },
        ].map((faq, index) => (
          <div class="py-6" data-accordion-item>
            <button
              class="flex w-full items-center justify-between text-left"
              aria-expanded="false"
              data-accordion-trigger
            >
              <span class="text-lg font-semibold text-gray-900 dark:text-white">
                {faq.question}
              </span>
              <svg
                class="h-5 w-5 flex-shrink-0 text-gray-500 transition-transform"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                data-accordion-icon
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="hidden pt-4" data-accordion-content>
              <p class="text-gray-600 dark:text-gray-400">
                {faq.answer}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>

<script>
  // Accordion functionality
  const accordionItems = document.querySelectorAll('[data-accordion-item]');

  accordionItems.forEach((item) => {
    const trigger = item.querySelector('[data-accordion-trigger]');
    const content = item.querySelector('[data-accordion-content]');
    const icon = item.querySelector('[data-accordion-icon]');

    trigger?.addEventListener('click', () => {
      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';

      // Close all other items
      accordionItems.forEach((otherItem) => {
        const otherTrigger = otherItem.querySelector('[data-accordion-trigger]');
        const otherContent = otherItem.querySelector('[data-accordion-content]');
        const otherIcon = otherItem.querySelector('[data-accordion-icon]');

        if (otherItem !== item) {
          otherTrigger?.setAttribute('aria-expanded', 'false');
          otherContent?.classList.add('hidden');
          otherIcon?.classList.remove('rotate-180');
        }
      });

      // Toggle current item
      trigger.setAttribute('aria-expanded', String(!isExpanded));
      content?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
