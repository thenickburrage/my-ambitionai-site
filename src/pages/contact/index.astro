---
import Base from '@/layouts/Base.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ContactPage",
      "@id": "https://theambitionsagency.com/contact/#webpage",
      "url": "https://theambitionsagency.com/contact/",
      "name": "Contact Ambitions AI — Book a Free Explore Call",
      "description": "Get in touch with Ambitions AI. Book a free Explore Call or send a message. We help service businesses grow using AI tools, SEO, AEO, and the Endless Customers methodology.",
      "publisher": { "@id": "https://theambitionsagency.com/#organization" },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://theambitionsagency.com/" },
          { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://theambitionsagency.com/contact/" }
        ]
      }
    },
    {
      "@type": "Organization",
      "@id": "https://theambitionsagency.com/#organization",
      "name": "Ambitions AI",
      "legalName": "Ambitions Web Ltd",
      "url": "https://theambitionsagency.com",
      "logo": "https://theambitionsagency.com/images/AAI_HEADERLOGO.webp",
      "email": "nb@theambitionsagency.com",
      "telephone": "+441752830000",
      "description": "Ambitions AI helps founder-led service businesses across the UK and USA grow using AI tools, SEO, AEO, content strategy, and the Endless Customers methodology.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "80 Magdalen Road",
        "addressLocality": "Exeter",
        "addressRegion": "Devon",
        "postalCode": "EX2 4TT",
        "addressCountry": "GB"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "sales",
        "email": "nb@theambitionsagency.com",
        "telephone": "+441752830000",
        "areaServed": ["GB", "US"],
        "availableLanguage": "English"
      },
      "founder": {
        "@type": "Person",
        "name": "Nick Burrage",
        "url": "https://theambitionsagency.com/authors/nick-burrage/",
        "sameAs": "https://www.linkedin.com/in/nicholas-burrage-digital-marketing"
      },
      "areaServed": ["GB", "US"],
      "sameAs": [
        "https://www.linkedin.com/in/nicholas-burrage-digital-marketing"
      ]
    }
  ]
};
---

<Base
  title="Contact"
  metaTitle="Contact Ambitions AI — Book a Free Explore Call"
  description="Get in touch with Ambitions AI. Book a free 20-minute Explore Call or send us a message. No pressure, no hard sell — just an honest conversation about your business."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <!-- =========================================================
       HERO
  ========================================================= -->
  <section class="relative overflow-hidden bg-gray-50 dark:bg-gray-900">
    <div class="absolute inset-0 opacity-30 dark:opacity-20">
      <div class="absolute -left-8 top-0 h-96 w-96 rounded-full bg-primary-500 blur-[160px]"></div>
      <div class="absolute -right-8 bottom-0 h-64 w-64 rounded-full bg-accent-500 blur-[140px]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 py-24 lg:px-8 lg:py-32">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500">Get in touch</p>
        <h1 class="mt-4 text-4xl font-normal leading-tight text-gray-900 dark:text-white sm:text-5xl lg:text-6xl">
          You want to get in touch.<br class="hidden sm:block" />
          <em class="italic text-primary-500">You just don't want to be hassled.</em>
        </h1>
        <p class="mx-auto mt-6 max-w-xl text-lg text-gray-600 dark:text-gray-400">
          No pressure, no hard sell. Just an honest conversation to see if we can genuinely help.
        </p>
      </div>
    </div>
  </section>

  <!-- Author credit -->
  <div class="border-b border-gray-200 bg-white py-4 dark:border-gray-800 dark:bg-gray-950">
    <div class="mx-auto flex max-w-7xl items-center justify-center gap-6 px-4 text-sm text-gray-400 dark:text-gray-500 lg:px-8">
      <span class="flex items-center gap-1.5">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
        </svg>
        Nick Burrage
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 9v7.5" />
        </svg>
        12 April 2026
      </span>
    </div>
  </div>

  <!-- =========================================================
       VIDEO PLACEHOLDER
  ========================================================= -->
  <section class="bg-white py-20 dark:bg-gray-950 lg:py-24">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="mx-auto max-w-3xl" data-animate>
        <p class="text-center text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500">
          Watch before you get in touch
        </p>

        <!-- Video placeholder panel -->
        <div class="mt-6 overflow-hidden rounded-2xl border border-gray-200 bg-gray-900 shadow-xl dark:border-gray-800">
          <div class="relative flex aspect-video flex-col items-center justify-center gap-4 px-8 text-center">
            <!-- Subtle background glow -->
            <div class="absolute inset-0 flex items-center justify-center opacity-20">
              <div class="h-64 w-64 rounded-full bg-primary-500 blur-[80px]"></div>
            </div>
            <!-- Play button -->
            <div class="relative flex h-16 w-16 items-center justify-center rounded-full border-2 border-white/30 bg-white/10 backdrop-blur-sm transition-all hover:bg-white/20">
              <svg class="ml-1 h-6 w-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
            <div class="relative">
              <h2 class="text-xl font-semibold text-white sm:text-2xl">What Happens If You Fill In This Form?</h2>
              <p class="mt-2 text-sm text-gray-400">90 seconds — exactly what to expect</p>
            </div>
            <span class="relative mt-2 inline-block rounded-full border border-primary-500/40 bg-primary-500/10 px-4 py-1.5 text-xs font-medium text-primary-300">
              Video coming soon
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================================
       BOOKING CTA
  ========================================================= -->
  <section class="bg-gray-50 py-20 dark:bg-gray-900 lg:py-24">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="mx-auto max-w-2xl text-center" data-animate>
        <h2 class="text-3xl font-normal text-gray-900 dark:text-white sm:text-4xl">
          Ready to talk? Book yourself straight in.
        </h2>
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
          Pick a time that suits you — no back and forth needed.
        </p>
        <div class="mt-10">
          <a
            href="https://calendar.app.google/nUXVfUBxqS4K4fSx8"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-primary-500 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-500/25 transition-all hover:bg-primary-600 hover:shadow-xl hover:shadow-primary-500/30"
          >
            Book a Free Explore Call →
          </a>
          <p class="mt-5 text-sm text-gray-500 dark:text-gray-400">
            20 minutes &middot; No obligation &middot; Pick a time that suits you
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================================
       DIVIDER
  ========================================================= -->
  <div class="relative bg-white py-12 dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="flex items-center gap-6">
        <div class="h-px flex-1 bg-gray-200 dark:bg-gray-800"></div>
        <p class="flex-shrink-0 text-sm font-medium text-gray-500 dark:text-gray-400">
          Prefer to drop us a message first?
        </p>
        <div class="h-px flex-1 bg-gray-200 dark:bg-gray-800"></div>
      </div>
    </div>
  </div>

  <!-- =========================================================
       CONTACT FORM
  ========================================================= -->
  <section class="bg-white pb-24 pt-4 dark:bg-gray-950 lg:pb-32">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="mx-auto max-w-2xl" data-animate>
        <h2 class="text-3xl font-normal text-gray-900 dark:text-white sm:text-4xl">
          Send us a message
        </h2>
        <p class="mt-3 text-gray-600 dark:text-gray-400">
          We'll come back to you within one working day.
        </p>

        <!-- Form wrapper — hidden on success -->
        <div id="contact-form-wrapper" class="mt-10">
          <form
            id="contact-form"
            class="space-y-6"
            novalidate
          >
            <!-- Web3Forms hidden fields -->
            <input type="hidden" name="access_key" value="db9eb6fd-eb2e-4499-8ba8-135383a6aee3">
            <input type="hidden" name="subject" value="New contact form submission — Ambitions AI">
            <input type="hidden" name="from_name" value="Ambitions AI Website">
            <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off">

            <div class="grid gap-6 sm:grid-cols-2">
              <!-- Name -->
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                  Your name <span class="text-primary-500">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Jane Smith"
                  class="mt-2 w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-gray-900 placeholder-gray-400 transition-colors focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 dark:border-gray-700 dark:bg-gray-900 dark:text-white dark:placeholder-gray-500 dark:focus:border-primary-400"
                />
              </div>

              <!-- Email -->
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                  Email address <span class="text-primary-500">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="jane@yourcompany.com"
                  class="mt-2 w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-gray-900 placeholder-gray-400 transition-colors focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 dark:border-gray-700 dark:bg-gray-900 dark:text-white dark:placeholder-gray-500 dark:focus:border-primary-400"
                />
              </div>
            </div>

            <!-- Business name -->
            <div>
              <label for="business" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                Business name
              </label>
              <input
                type="text"
                id="business"
                name="business"
                placeholder="Your business name"
                class="mt-2 w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-gray-900 placeholder-gray-400 transition-colors focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 dark:border-gray-700 dark:bg-gray-900 dark:text-white dark:placeholder-gray-500 dark:focus:border-primary-400"
              />
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                What made you stop and fill this in today? <span class="text-primary-500">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Tell us what's on your mind — don't hold back."
                class="mt-2 w-full resize-none rounded-xl border border-gray-300 bg-white px-4 py-3 text-gray-900 placeholder-gray-400 transition-colors focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 dark:border-gray-700 dark:bg-gray-900 dark:text-white dark:placeholder-gray-500 dark:focus:border-primary-400"
              ></textarea>
            </div>

            <!-- Error message -->
            <div id="form-error" class="hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-800 dark:bg-red-900/20 dark:text-red-400">
              Something went wrong. Please try again or email us directly at
              <a href="mailto:nb@theambitionsagency.com" class="underline">nb@theambitionsagency.com</a>.
            </div>

            <!-- Submit -->
            <div>
              <button
                type="submit"
                id="submit-btn"
                class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-primary-500 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-500/25 transition-all hover:bg-primary-600 hover:shadow-xl hover:shadow-primary-500/30 disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto"
              >
                <span id="submit-label">Let's Talk →</span>
                <svg id="submit-spinner" class="hidden h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
              </button>
              <p class="mt-4 text-xs text-gray-500 dark:text-gray-400">
                We typically respond within one working day.<br />
                Your details are never shared with anyone.
              </p>
            </div>
          </form>
        </div>

        <!-- Success message — hidden until submission -->
        <div id="contact-success" class="hidden">
          <div class="rounded-2xl border border-green-200 bg-green-50 p-8 dark:border-green-800 dark:bg-green-900/20">
            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-green-100 dark:bg-green-800">
                <svg class="h-5 w-5 text-green-600 dark:text-green-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Message received — thank you.</h3>
                <p class="mt-2 text-gray-600 dark:text-gray-300">
                  We'll be in touch within one working day. In the meantime, feel free to browse the
                  <a href="/learning-centre/" class="font-medium text-primary-600 hover:underline dark:text-primary-400">Learning Centre</a>.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const wrapper = document.getElementById('contact-form-wrapper');
  const success = document.getElementById('contact-success');
  const errorBox = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('submit-label');
  const submitSpinner = document.getElementById('submit-spinner');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !form) return;

    // Reset error state
    errorBox?.classList.add('hidden');

    // Loading state
    submitBtn.disabled = true;
    submitLabel?.classList.add('hidden');
    submitSpinner?.classList.remove('hidden');

    try {
      const data = new FormData(form);
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: data,
      });
      const result = await response.json();

      if (result.success) {
        wrapper?.classList.add('hidden');
        success?.classList.remove('hidden');
      } else {
        throw new Error(result.message ?? 'Submission failed');
      }
    } catch {
      errorBox?.classList.remove('hidden');
      submitBtn.disabled = false;
      submitLabel?.classList.remove('hidden');
      submitSpinner?.classList.add('hidden');
    }
  });
</script>
