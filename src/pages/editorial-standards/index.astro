---
import Base from '@/layouts/Base.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": "https://theambitionsagency.com/editorial-standards/#webpage",
  "url": "https://theambitionsagency.com/editorial-standards/",
  "name": "Editorial Standards",
  "description": "How Ambitions AI approaches the content we create, and why you can trust what we publish.",
  "inLanguage": "en-GB",
  "isPartOf": {
    "@type": "WebSite",
    "@id": "https://theambitionsagency.com/#website",
    "name": "Ambitions AI",
    "url": "https://theambitionsagency.com/"
  },
  "about": { "@id": "https://theambitionsagency.com/#organization" },
  "publisher": { "@id": "https://theambitionsagency.com/#organization" }
};
---

<Base
  title="Editorial Standards"
  description="How Ambitions AI approaches the content we create, and why you can trust what we publish."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <section class="bg-white py-16 dark:bg-gray-950 lg:py-20">
    <div class="mx-auto max-w-3xl px-4 lg:px-8">

      <h1 class="text-3xl font-normal text-gray-900 dark:text-white sm:text-4xl">
        Editorial Standards
      </h1>
      <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">
        Ambitions Web Ltd (trading as Ambitions AI and CXSolved.AI) -- Company No. 15387454
      </p>

      <div class="prose prose-gray mt-10 max-w-none dark:prose-invert">

        <h2>Introduction</h2>
        <p>Every piece of content published by Ambitions AI is held to a high standard. This page explains how we approach the content we create -- and why you can trust what we publish.</p>

        <h2>Who reviews our content</h2>
        <p>All content published by Ambitions AI is reviewed and approved by Nick Burrage. Nick is a trained journalist with extensive professional copywriting experience, having worked on campaigns for some of the world's most recognised brands, including Ford, Samsung, and Sky TV. That background shapes the quality bar we apply to everything that goes out under our name.</p>

        <h2>Originality</h2>
        <p>We don't copy, rehash, or lightly repackage other people's work. When we publish something, it represents our own thinking, expertise, and perspective. We write from knowledge, not from shortcuts.</p>

        <h2>Expertise-led content</h2>
        <p>We only write about subjects we genuinely know well. Our content is drawn from hands-on experience working with clients, staying current with the latest tools and techniques, and thinking carefully about how AI is changing marketing. We don't publish outside our area of expertise.</p>

        <h2>Clarity over cleverness</h2>
        <p>We write to be understood, not to impress. If a point can be made simply, we make it simply.</p>

        <h2>Getting it right from the start</h2>
        <p>Our editorial standards are built into how we create content -- not applied as an afterthought. Because we write carefully, from genuine expertise, and with proper review, errors are exceptionally rare. The standard is set before anything is published, not after.</p>

      </div>
    </div>
  </section>
</Base>
