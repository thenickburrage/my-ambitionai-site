---
import Base from '@/layouts/Base.astro';
---

<Base title="Your No.1 Salesperson" description="Coming soon — discover how your website becomes your best salesperson.">
  <section class="bg-gray-50 py-20 dark:bg-gray-900 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl lg:text-6xl">
          Your No.1 Salesperson
        </h1>
        <p class="mt-6 text-lg text-gray-600 dark:text-gray-400">
          Coming soon — discover how your website becomes your best salesperson.
        </p>
        <div class="mt-10">
          <a
            href="/contact/"
            class="inline-flex rounded-full bg-primary-500 px-8 py-3 text-sm font-semibold text-white shadow-lg shadow-primary-500/25 transition-all hover:bg-primary-600 hover:shadow-xl hover:shadow-primary-500/30"
          >
            Get in Touch
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
