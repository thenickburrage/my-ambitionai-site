---
import Base from '@/layouts/Base.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": "https://theambitionsagency.com/security/#webpage",
  "url": "https://theambitionsagency.com/security/",
  "name": "Security",
  "description": "How Ambitions AI protects its website, platforms, and the data entrusted to us.",
  "inLanguage": "en-GB",
  "isPartOf": {
    "@type": "WebSite",
    "@id": "https://theambitionsagency.com/#website",
    "name": "Ambitions AI",
    "url": "https://theambitionsagency.com/"
  },
  "about": { "@id": "https://theambitionsagency.com/#organization" },
  "publisher": { "@id": "https://theambitionsagency.com/#organization" }
};
---

<Base
  title="Security"
  description="How Ambitions AI protects its website, platforms, and the data entrusted to us."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <section class="bg-white py-16 dark:bg-gray-950 lg:py-20">
    <div class="mx-auto max-w-3xl px-4 lg:px-8">

      <h1 class="text-3xl font-normal text-gray-900 dark:text-white sm:text-4xl">
        Security
      </h1>
      <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">
        Ambitions Web Ltd (trading as Ambitions AI and CXSolved.AI) -- Company No. 15387454
      </p>

      <div class="prose prose-gray mt-10 max-w-none dark:prose-invert">

        <h2>Introduction</h2>
        <p>We take the security of our systems -- and the data entrusted to us -- seriously. This page sets out how we protect our website, our platforms, and the information we hold.</p>

        <h2>Website security</h2>
        <p>Our website is built on Cloudflare's infrastructure, which provides enterprise-grade protection including DDoS mitigation, firewall rules, and performance optimisation. All connections to our site are encrypted via SSL/HTTPS. Our systems are kept up to date, and access is controlled and restricted to authorised users only.</p>

        <h2>Account and system security</h2>
        <p>Two-factor authentication (2FA) is enabled across our systems. We take password security seriously across every platform we operate, including the tools we use to power our AI voice systems and conversation storage.</p>

        <h2>Data we collect</h2>
        <p>Through our website and services, we may collect information submitted via contact forms, manage an email list, and maintain client records in our CRM system. We collect only what we need, store it securely, and do not share it with third parties without consent.</p>

        <h2>ICO Registration</h2>
        <p>Ambitions Web Ltd is registered with the Information Commissioner's Office (ICO) -- the UK's independent body for data rights and information privacy. This registration reflects our legal responsibilities under UK GDPR and our commitment to handling personal data properly and transparently.</p>
        <p>Registration number: ZB804022<br />
        <a href="https://ico.org.uk/ESDWebPages/Entry/ZB804022" target="_blank" rel="noopener noreferrer">View our ICO registration</a></p>

        <h2>Incident response</h2>
        <p>In the unlikely event of a security incident or data breach, we have a clear process for responding -- including assessing the situation quickly, containing any impact, notifying affected parties where required, and reporting to the ICO in line with our legal obligations.</p>

        <h2>Questions?</h2>
        <p>If you have any questions about how we handle your data or our security practices, please get in touch.</p>
        <p><a href="/contact/">Contact us</a></p>

      </div>
    </div>
  </section>
</Base>
