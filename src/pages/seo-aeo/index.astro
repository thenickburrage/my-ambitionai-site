---
import Base from '@/layouts/Base.astro';
import LeadMagnet from '@/components/LeadMagnet.astro';

const publishedISO = '2026-04-20';
const updatedISO   = '2026-04-20';

const faqs = [
  {
    q: 'Do I need SEO and AEO if I already have content coaching with you?',
    a: 'Yes, and most of our content coaching clients do both. Content coaching teaches your team to produce the work. SEO and AEO make sure the work is found, cited, and ranked properly.',
  },
  {
    q: 'Do I need a new website first?',
    a: 'Maybe, maybe not. The first thing we do is audit your existing site. If it is in reasonable shape, we work with what you have. If there are structural issues blocking everything else, we will tell you honestly and discuss whether a rebuild makes sense.',
  },
  {
    q: 'How long until I see results?',
    a: 'Typically the commercial impact shows up between months three and five. Some of the work we do in month one, like Google Business Profile rebuilds, technical unblocking, and wrong-country traffic cleanup, shows visible change within weeks. We will always be clear about what to expect and when.',
  },
  {
    q: 'What about link-building?',
    a: 'We do not do link-building schemes. Ever. They damage your domain, waste your money, and modern search engines see straight through them. Quality backlinks come from being genuinely worth linking to, and that is a content problem.',
  },
  {
    q: 'Do you guarantee rankings?',
    a: 'No. In an age of AI, ranking guarantees are meaningless anyway, and anyone who does guarantee them is either lying or out of date. What we guarantee is that the right work gets done, honestly, by people who know what they are doing, every single week.',
  },
  {
    q: 'What if I need to stop?',
    a: 'No contracts, no minimum terms beyond the month. You can stop whenever you want. If we are not earning it every month, we do not deserve to keep it.',
  },
  {
    q: 'How much does it cost?',
    a: '£120 / $150 per hour, minimum 10 hours per month, typical engagement around £2,000 / $2,500 per month. Bundle discounts available.',
  },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://theambitionsagency.com/seo-aeo/#webpage",
      "url": "https://theambitionsagency.com/seo-aeo/",
      "name": "SEO and AEO That Actually Gets You Found in 2026 | Ambitions AI",
      "description": "SEO and AEO work done the modern way. Technical audit, ongoing optimisation, AI visibility, and honest reporting. For service businesses in the UK and USA. From £2,000 / $2,500 per month.",
      "datePublished": publishedISO,
      "dateModified": updatedISO,
      "author": { "@id": "https://theambitionsagency.com/#nick-burrage" },
      "publisher": { "@id": "https://theambitionsagency.com/#organization" },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",       "item": "https://theambitionsagency.com/" },
          { "@type": "ListItem", "position": 2, "name": "SEO & AEO",  "item": "https://theambitionsagency.com/seo-aeo/" }
        ]
      }
    },
    {
      "@type": "Service",
      "@id": "https://theambitionsagency.com/seo-aeo/#service",
      "name": "SEO and AEO",
      "description": "Modern technical SEO and Answer Engine Optimisation (AEO) for service businesses in the UK and USA. Includes technical audit, Google Business Profile optimisation, schema markup, competitive analysis, location page work, AI visibility optimisation, and monthly tracking.",
      "serviceType": "SEO and Answer Engine Optimisation",
      "url": "https://theambitionsagency.com/seo-aeo/",
      "provider": {
        "@type": "ProfessionalService",
        "@id": "https://theambitionsagency.com/#organization",
        "name": "Ambitions AI",
        "url": "https://theambitionsagency.com"
      },
      "areaServed": [
        { "@type": "Country", "name": "United Kingdom" },
        { "@type": "Country", "name": "United States" }
      ],
      "offers": {
        "@type": "Offer",
        "price": "120",
        "priceCurrency": "GBP",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "120",
          "priceCurrency": "GBP",
          "unitText": "HUR",
          "description": "Per hour. Minimum 10 hours per month. Typical engagement around £2,000 / $2,500 per month."
        },
        "availability": "https://schema.org/InStock",
        "url": "https://theambitionsagency.com/pricing/"
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://theambitionsagency.com/seo-aeo/#faq",
      "mainEntity": faqs.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a },
      })),
    },
    {
      "@type": "Person",
      "@id": "https://theambitionsagency.com/#nick-burrage",
      "name": "Nick Burrage",
      "url": "https://theambitionsagency.com/authors/nick-burrage/",
      "jobTitle": "Founder",
      "worksFor": { "@id": "https://theambitionsagency.com/#organization" }
    }
  ]
};
---

<Base
  title="SEO & AEO"
  metaTitle="SEO and AEO That Actually Gets You Found in 2026 | Ambitions AI"
  description="SEO and AEO work done the modern way. Technical audit, ongoing optimisation, AI visibility, and honest reporting. For service businesses in the UK and USA. From £2,000 / $2,500 per month."
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <!-- =========================================================
       SECTION 1 — HERO
  ========================================================= -->
  <section class="relative overflow-hidden bg-gray-50 dark:bg-gray-900">
    <div class="absolute inset-0 opacity-30 dark:opacity-20">
      <div class="absolute -left-8 top-0 h-96 w-96 rounded-full bg-primary-500 blur-[160px]"></div>
      <div class="absolute -right-8 bottom-0 h-96 w-96 rounded-full bg-accent-500 blur-[160px]"></div>
    </div>

    <div class="relative mx-auto max-w-4xl px-4 py-24 text-center lg:px-8 lg:py-32">
      <p class="text-sm font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500">SEO &amp; AEO</p>
      <h1 class="mt-4 text-4xl font-normal leading-tight text-gray-900 dark:text-white sm:text-5xl lg:text-6xl">
        <span class="font-bold">SEO and AEO That Actually Work.</span>
        <em class="mt-2 block italic text-primary-500">For the AI Age.</em>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
        Old-school SEO was built for a different internet. Today, your buyers are half-human, half-AI. We make sure both can find you, trust you, and choose you.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/contact/" class="inline-flex items-center gap-2 rounded-full bg-primary-500 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-500/25 transition-all hover:bg-primary-600">
          Start Now
        </a>
        <a href="#how-it-works" class="inline-flex items-center gap-2 rounded-full border-2 border-gray-300 px-8 py-4 text-base font-semibold text-gray-700 transition-all hover:border-gray-400 hover:bg-white dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-800">
          See How It Works
        </a>
      </div>
    </div>
  </section>

  <!-- Author credit + date -->
  <div class="border-b border-gray-200 bg-white py-4 dark:border-gray-800 dark:bg-gray-950">
    <div class="mx-auto flex max-w-7xl items-center justify-center gap-6 px-4 text-sm text-gray-400 dark:text-gray-500 lg:px-8">
      <span class="flex items-center gap-1.5">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
        </svg>
        Nick Burrage
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 9v7.5" />
        </svg>
        20 April 2026
      </span>
    </div>
  </div>

  <!-- =========================================================
       SECTION 2 — PROBLEM AND STAKES
  ========================================================= -->
  <section class="bg-white py-16 lg:py-20 dark:bg-gray-950">
    <div class="mx-auto max-w-3xl px-4 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary-500">The problem</p>
      <h2 class="mt-3 text-3xl text-gray-900 dark:text-white lg:text-4xl">
        A few things I hear when I meet service business owners.
      </h2>

      <div class="mt-8 space-y-4">
        {[
          'We had an SEO agency for three years. I genuinely could not tell you what they did for the money.',
          'Google sends us traffic, but none of them are the right people.',
          'AI now answers the question before anyone even clicks. I have no idea how to get in front of that.',
        ].map((quote) => (
          <blockquote class="relative rounded-2xl border-l-4 border-primary-500 bg-gray-50 py-5 pl-6 pr-6 dark:bg-gray-900">
            <p class="text-lg italic text-gray-700 dark:text-gray-300 before:content-['\u2018'] after:content-['\u2019']">{quote}</p>
          </blockquote>
        ))}
      </div>

      <p class="mt-8 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        If any of those sound familiar, you are in the right place. Most businesses have been paying for some form of SEO for years without ever really understanding what was happening behind the curtain.
      </p>

      <!-- Dominant pull-out 1 -->
      <figure class="my-12 rounded-2xl border border-primary-200 bg-primary-50 p-8 dark:border-primary-800 dark:bg-primary-950/40">
        <blockquote>
          <p class="font-display text-2xl font-semibold leading-snug text-gray-900 dark:text-white lg:text-3xl">
            &lsquo;SEO without a content flow is a bucket with no tap. You are trying to fill something that never has anything going in.&rsquo;
          </p>
        </blockquote>
      </figure>

      <p class="text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        Here is the uncomfortable truth. SEO and AEO are not magic. They are detail work, done consistently, on top of content worth finding. If nobody has been paying attention to the detail, your rankings slowly crumble. And if nobody is producing fresh content, no amount of technical work will make the business grow.
      </p>

      <p class="mt-6 text-lg font-semibold text-gray-900 dark:text-white">
        So here is the question: is the detail work being done on your site, right now, every week?
      </p>
    </div>
  </section>

  <!-- =========================================================
       SECTION 3 — THE GUIDE STEPS IN
  ========================================================= -->
  <section class="bg-gray-50 py-16 dark:bg-gray-900 lg:py-20">
    <div class="mx-auto max-w-3xl px-4 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary-500">The approach</p>
      <h2 class="mt-3 text-3xl text-gray-900 dark:text-white lg:text-4xl">
        The Work Is Technical. The Relationship Is Not.
      </h2>

      <p class="mt-8 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        I am Nick Burrage, and I do not write schema markup. That work is handled by a specialist team.
      </p>

      <p class="mt-5 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        My job is different, and it is the bit most SEO agencies do badly or not at all.
      </p>

      <p class="mt-5 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        I am the link between what the technical team is doing and what is actually happening in your business. When the data says a page is ranking brilliantly for a particular query, I am the one who asks <em>you</em> whether that query is bringing you the right people. When something in the technical plan would affect the content you are producing, I make the adjustment in both directions.
      </p>

      <!-- Strong pull-out 1 -->
      <figure class="my-10 border-l-4 border-primary-500 pl-6">
        <blockquote>
          <p class="font-display text-xl italic leading-snug text-gray-900 dark:text-white lg:text-2xl">
            &lsquo;The technical people tell you which keyword to hit. They cannot tell you how to write the article so it resonates with both humans and AI. That is the link nobody else does.&rsquo;
          </p>
        </blockquote>
      </figure>

      <p class="text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        If you are already on our <a href="/endless-customers-coaching/" class="font-semibold text-primary-500 hover:text-primary-600">Endless Customers coaching programme</a>, that link becomes seamless. If you are not, the link still matters.
      </p>

      <p class="mt-5 text-lg font-semibold text-gray-900 dark:text-white">
        That is the job.
      </p>
    </div>
  </section>

  <!-- =========================================================
       SECTION 4 — PROOF
  ========================================================= -->
  <section class="bg-white py-16 lg:py-20 dark:bg-gray-950">
    <div class="mx-auto max-w-5xl px-4 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-primary-500">Real work, real results</p>
        <h2 class="mt-3 text-3xl font-semibold text-gray-900 dark:text-white sm:text-4xl lg:text-5xl">
          Here Is What This Work Unlocks.
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
          We do not publish dramatic ranking screenshots. Most of our SEO and AEO wins involve real client data we have agreed to keep private. What we can share are the stories of what modern technical work actually looks like in practice.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-3">

        <!-- CARD 1 -->
        <div class="flex flex-col rounded-2xl border border-gray-100 bg-gray-50 p-8 dark:border-gray-800 dark:bg-gray-900">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-100 text-primary-600 dark:bg-primary-900 dark:text-primary-300">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM14.06 6.19l3.75 3.75M3 3l18 18" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 19l6-6 4 4 8-8" />
            </svg>
          </div>
          <p class="mt-6 font-display text-4xl font-semibold text-gray-900 dark:text-white lg:text-5xl">290 &rarr; 1,200</p>
          <p class="mt-2 text-sm font-semibold uppercase tracking-widest text-primary-500">Monthly traffic, year one</p>
          <p class="mt-4 flex-1 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
            <strong class="text-gray-900 dark:text-white">Katherine, UK. Premium curtains and blinds.</strong> Monthly organic traffic climbed from around 290 visits to over 1,200 in year one, alongside the Endless Customers content programme. Content plus SEO &amp; AEO, working together, delivered something neither would have alone.
          </p>
        </div>

        <!-- CARD 2 -->
        <div class="flex flex-col rounded-2xl border border-gray-100 bg-gray-50 p-8 dark:border-gray-800 dark:bg-gray-900">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-100 text-primary-600 dark:bg-primary-900 dark:text-primary-300">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
            </svg>
          </div>
          <p class="mt-6 font-display text-4xl font-semibold text-gray-900 dark:text-white lg:text-5xl">70%</p>
          <p class="mt-2 text-sm font-semibold uppercase tracking-widest text-primary-500">Wrong-country traffic, eliminated</p>
          <p class="mt-4 flex-1 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
            <strong class="text-gray-900 dark:text-white">Roofing client, USA.</strong> On day one we discovered that seventy percent of the client's website traffic was coming from Singapore, China, and Pakistan. Not a single one of them a buyer. We cleaned it up first, then rebuilt the targeting toward real US buyers. Raw traffic went down. Real leads went up.
          </p>
        </div>

        <!-- CARD 3 -->
        <div class="flex flex-col rounded-2xl border border-gray-100 bg-gray-50 p-8 dark:border-gray-800 dark:bg-gray-900">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-100 text-primary-600 dark:bg-primary-900 dark:text-primary-300">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <p class="mt-6 font-display text-4xl font-semibold text-gray-900 dark:text-white lg:text-5xl">100%</p>
          <p class="mt-2 text-sm font-semibold uppercase tracking-widest text-primary-500">Google Business Profiles cleaned up</p>
          <p class="mt-4 flex-1 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
            Almost every new client arrives with a Google Business Profile that is incomplete, misaligned with their website, or missing the categories and attributes that actually drive local and local-AI discovery. Every single one gets properly rebuilt in the first month.
          </p>
        </div>

      </div>

      <!-- Strong pull-out 2 -->
      <figure class="mt-12 border-l-4 border-primary-500 pl-6">
        <blockquote>
          <p class="font-display text-xl italic leading-snug text-gray-900 dark:text-white lg:text-2xl">
            &lsquo;Seventy percent of their website traffic was coming from Singapore, China, and Pakistan. None of it was people who wanted a roof.&rsquo;
          </p>
        </blockquote>
      </figure>

      <p class="mt-8 text-center font-display text-xl italic text-gray-700 dark:text-gray-300">
        &rarr; The detail is where the difference is made.
      </p>

      <div class="mt-10 text-center">
        <a href="/contact/" class="inline-flex items-center gap-2 rounded-full bg-primary-500 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-500/25 transition-all hover:bg-primary-600">
          Start Now
        </a>
      </div>
    </div>
  </section>

  <!-- =========================================================
       SECTION 5 — THE ANSWER
  ========================================================= -->
  <section id="how-it-works" class="bg-gray-50 py-16 dark:bg-gray-900 lg:py-20">
    <div class="mx-auto max-w-3xl px-4 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary-500">The answer</p>
      <h2 class="mt-3 text-3xl text-gray-900 dark:text-white lg:text-4xl">
        What Modern SEO and AEO Actually Is. And Why It Changes Your Business.
      </h2>

      <p class="mt-8 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        Two terms, briefly, because they matter:
      </p>

      <div class="mt-6 space-y-4">
        <div class="rounded-2xl border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-gray-950">
          <p class="text-lg text-gray-700 dark:text-gray-300">
            <strong class="text-gray-900 dark:text-white">SEO</strong> (Search Engine Optimisation) makes sure search engines, Google, Bing, and the rest, can find your site, understand it, rank it, and send you the right kind of visitor.
          </p>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-gray-950">
          <p class="text-lg text-gray-700 dark:text-gray-300">
            <strong class="text-gray-900 dark:text-white">AEO</strong> (Answer Engine Optimisation) makes sure your content is structured so search systems and AI tools can extract a direct answer and cite you as the source.
          </p>
        </div>
      </div>

      <p class="mt-8 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        Together, they are the technical infrastructure that keeps you findable.
      </p>

      <!-- Dominant pull-out 2 -->
      <figure class="my-12 rounded-2xl border border-primary-200 bg-primary-50 p-8 dark:border-primary-800 dark:bg-primary-950/40">
        <blockquote>
          <p class="font-display text-2xl font-semibold leading-snug text-gray-900 dark:text-white lg:text-3xl">
            &lsquo;Most SEO agencies learn their trade at a certain time and get stuck in it. In April 2026 that is the single most expensive mistake you can make.&rsquo;
          </p>
        </blockquote>
      </figure>

      <h3 class="mt-12 text-2xl text-gray-900 dark:text-white">
        The New Buyer Has Already Left Google. Their AI Is Doing the Looking.
      </h3>

      <p class="mt-5 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        Picture your buyer six months from now. They say to their AI: <em>&lsquo;I need my garden taken care of. I have a budget of X a month. Go and find me two or three good gardening services and book them in to visit me. I will pick the winner.&rsquo;</em>
      </p>

      <p class="mt-5 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        The AI goes off and does the work. It reads your reviews. It checks whether you work in their area. It pulls from your website, your Google Business Profile, your third-party mentions, your schema, your content. Then it hands its human a shortlist.
      </p>

      <p class="mt-5 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        Your future buyer may never visit your website. But the AI that gets them to you absolutely will.
      </p>

      <h3 class="mt-12 text-2xl text-gray-900 dark:text-white">
        What Does That Mean for You? You Wake Up Booked.
      </h3>

      <p class="mt-5 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        This is the power of doing the work properly, especially when combined with AI booking automations on your site. Monday morning looks different:
      </p>

      <ul class="mt-6 space-y-3 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        <li class="flex gap-3"><span class="mt-2.5 block h-1.5 w-1.5 shrink-0 rounded-full bg-primary-500"></span><span>You open your diary and it is already full for the week</span></li>
        <li class="flex gap-3"><span class="mt-2.5 block h-1.5 w-1.5 shrink-0 rounded-full bg-primary-500"></span><span>Your sales team are rushed off their feet trying to get to all the new bookings</span></li>
        <li class="flex gap-3"><span class="mt-2.5 block h-1.5 w-1.5 shrink-0 rounded-full bg-primary-500"></span><span>You find yourself running low on stock. Or booking an extra holiday. Or hiring the pair of hands you have been putting off</span></li>
        <li class="flex gap-3"><span class="mt-2.5 block h-1.5 w-1.5 shrink-0 rounded-full bg-primary-500"></span><span><strong class="text-gray-900 dark:text-white">You stop paying for Google Ads</strong>, because you no longer need them</span></li>
      </ul>

      <p class="mt-8 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        This is not marketing fluff. It is the direction the market is moving in, faster than most business owners realise. The businesses being cited by AI in 2026 are the ones doing this work now.
      </p>

      <h3 class="mt-12 text-2xl text-gray-900 dark:text-white">
        Bonus: Your Google Ads Will Suddenly Cost Less.
      </h3>

      <p class="mt-5 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        Here is one we find almost every time we audit a new site.
      </p>

      <p class="mt-5 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
