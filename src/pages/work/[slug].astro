---
import Base from '@/layouts/Base.astro';
import { projects } from '@/data/site';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

// Find related projects (same category, excluding current)
const relatedProjects = projects
  .filter((p) => p.category === project.category && p.slug !== project.slug)
  .slice(0, 2);
---

<Base title={project.title} description={project.description}>
  <!-- Hero -->
  <section class="bg-gray-50 py-20 dark:bg-gray-900 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <!-- Breadcrumb -->
        <nav class="mb-8 flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
          <a href="/work" class="hover:text-primary-500">Work</a>
          <span>/</span>
          <span class="text-gray-900 dark:text-white">{project.title}</span>
        </nav>

        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-4">
          <span class="rounded-full bg-primary-100 px-4 py-1.5 text-sm font-medium text-primary-700 dark:bg-primary-900/30 dark:text-primary-300">
            {project.category}
          </span>
          <span class="text-sm text-gray-500 dark:text-gray-400">{project.year}</span>
        </div>

        <!-- Title -->
        <h1 class="mt-6 text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl">
          {project.title}
        </h1>

        <!-- Description -->
        <p class="mt-6 text-xl text-gray-600 dark:text-gray-400">
          {project.description}
        </p>

        <!-- Services Tags -->
        <div class="mt-8 flex flex-wrap gap-2">
          {project.services.map((service) => (
            <span class="rounded-full border border-gray-300 px-4 py-1.5 text-sm text-gray-700 dark:border-gray-700 dark:text-gray-300">
              {service}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Image -->
  <section class="bg-white dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="overflow-hidden rounded-2xl">
        <img
          src={project.thumbnail}
          alt={project.title}
          class="h-auto w-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Case Study Content -->
  {(project.challenge || project.solution || project.results) && (
    <section class="bg-white py-20 dark:bg-gray-950 lg:py-28">
      <div class="mx-auto max-w-4xl px-4 lg:px-8">
        <div class="grid gap-12 lg:gap-16">
          {project.challenge && (
            <div>
              <h2 class="text-sm font-semibold uppercase tracking-wider text-primary-500">
                The Challenge
              </h2>
              <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
                {project.challenge}
              </p>
            </div>
          )}

          {project.solution && (
            <div>
              <h2 class="text-sm font-semibold uppercase tracking-wider text-primary-500">
                Our Solution
              </h2>
              <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
                {project.solution}
              </p>
            </div>
          )}

          {project.results && project.results.length > 0 && (
            <div>
              <h2 class="text-sm font-semibold uppercase tracking-wider text-primary-500">
                The Results
              </h2>
              <ul class="mt-6 grid gap-4 sm:grid-cols-3">
                {project.results.map((result) => (
                  <li class="rounded-xl bg-gray-50 p-6 text-center dark:bg-gray-900">
                    <span class="text-lg font-semibold text-gray-900 dark:text-white">
                      {result}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- Related Projects -->
  {relatedProjects.length > 0 && (
    <section class="bg-gray-50 py-20 dark:bg-gray-900 lg:py-28">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="flex items-end justify-between">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
              Related Projects
            </h2>
          </div>
          <a
            href="/work"
            class="text-sm font-semibold text-primary-500 hover:text-primary-600"
          >
            View All Work &rarr;
          </a>
        </div>

        <div class="mt-10 grid gap-8 sm:grid-cols-2">
          {relatedProjects.map((related) => (
            <a
              href={`/work/${related.slug}`}
              class="group relative overflow-hidden rounded-2xl bg-gray-900"
            >
              <div class="aspect-[4/3] overflow-hidden">
                <img
                  src={related.thumbnail}
                  alt={related.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                />
              </div>
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-gray-900/90 to-transparent p-6">
                <span class="text-xs font-medium uppercase tracking-wider text-primary-400">
                  {related.category}
                </span>
                <h3 class="mt-1 text-lg font-bold text-white">
                  {related.title}
                </h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-white py-20 dark:bg-gray-950">
    <div class="mx-auto max-w-4xl px-4 text-center lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">
        Like what you see?
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
        Let's discuss how we can help bring your project to life.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-flex items-center justify-center gap-2 rounded-full bg-primary-500 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-500/25 transition-all hover:bg-primary-600 hover:shadow-xl hover:shadow-primary-500/30"
      >
        Start Your Project
      </a>
    </div>
  </section>
</Base>
