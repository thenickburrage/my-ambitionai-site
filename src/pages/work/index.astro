---
import Base from '@/layouts/Base.astro';
import { projects } from '@/data/site';

const categories = ['All', ...new Set(projects.map((p) => p.category))];
---

<Base title="Work" description="Explore our portfolio of award-winning digital projects.">
  <!-- Page Header -->
  <section class="bg-gray-50 py-20 dark:bg-gray-900 lg:py-28">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl lg:text-6xl">
          Our Work
        </h1>
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
          A showcase of our best projects across branding, web design, mobile apps, and digital experiences.
        </p>
      </div>

      <!-- Filters -->
      <div class="mt-10 flex flex-wrap justify-center gap-3" id="portfolio-filters">
        {categories.map((category, index) => (
          <button
            class={`rounded-full px-5 py-2 text-sm font-medium transition-colors ${
              index === 0
                ? 'bg-primary-500 text-white'
                : 'border border-gray-300 text-gray-700 hover:border-primary-500 hover:text-primary-500 dark:border-gray-700 dark:text-gray-300 dark:hover:border-primary-500 dark:hover:text-primary-400'
            }`}
            data-filter={category === 'All' ? 'all' : category}
          >
            {category}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="bg-white py-20 dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3" id="portfolio-grid">
        {projects.map((project, index) => (
          <a
            href={`/work/${project.slug}`}
            class="group relative overflow-hidden rounded-2xl bg-gray-900"
            data-category={project.category}
            data-animate
            style={`animation-delay: ${index * 50}ms`}
          >
            <!-- Image -->
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={project.thumbnail}
                alt={project.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
              />
            </div>

            <!-- Overlay -->
            <div class="absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-gray-900 via-gray-900/60 to-transparent p-6 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              <span class="text-xs font-medium uppercase tracking-wider text-primary-400">
                {project.category} &bull; {project.year}
              </span>
              <h3 class="mt-2 text-xl font-bold text-white">
                {project.title}
              </h3>
              <p class="mt-2 line-clamp-2 text-sm text-gray-300">
                {project.description}
              </p>
              <div class="mt-4 flex flex-wrap gap-2">
                {project.services.slice(0, 3).map((service) => (
                  <span class="rounded-full bg-white/20 px-3 py-1 text-xs text-white">
                    {service}
                  </span>
                ))}
              </div>
            </div>

            <!-- Always visible label -->
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-gray-900/90 to-transparent p-6 transition-opacity duration-300 group-hover:opacity-0">
              <span class="text-xs font-medium uppercase tracking-wider text-primary-400">
                {project.category}
              </span>
              <h3 class="mt-1 text-lg font-bold text-white">
                {project.title}
              </h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-gray-50 py-20 dark:bg-gray-900">
    <div class="mx-auto max-w-4xl px-4 text-center lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">
        Ready to start your project?
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
        Let's create something amazing together.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-flex items-center justify-center gap-2 rounded-full bg-primary-500 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-500/25 transition-all hover:bg-primary-600 hover:shadow-xl hover:shadow-primary-500/30"
      >
        Start a Project
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Base>

<script>
  // Portfolio filter functionality
  const filters = document.querySelectorAll('#portfolio-filters button');
  const items = document.querySelectorAll('#portfolio-grid > a');

  filters.forEach((filter) => {
    filter.addEventListener('click', () => {
      const category = filter.getAttribute('data-filter');

      // Update active filter styles
      filters.forEach((f) => {
        f.classList.remove('bg-primary-500', 'text-white');
        f.classList.add('border', 'border-gray-300', 'text-gray-700', 'hover:border-primary-500', 'hover:text-primary-500', 'dark:border-gray-700', 'dark:text-gray-300');
      });
      filter.classList.add('bg-primary-500', 'text-white');
      filter.classList.remove('border', 'border-gray-300', 'text-gray-700', 'hover:border-primary-500', 'hover:text-primary-500', 'dark:border-gray-700', 'dark:text-gray-300');

      // Filter items
      items.forEach((item) => {
        const itemCategory = item.getAttribute('data-category');
        if (category === 'all' || itemCategory === category) {
          item.style.display = 'block';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
</script>
